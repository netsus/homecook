    "segments": [
      {
        "lineIndex": 0,
        "text": "왜 집에서 많은 김밥은 항상",
        "startMs": 160,
        "durationMs": 4119,
        "language": "ko"
      },
      {
        "lineIndex": 1,
        "text": "터질까요? 대부분이 김밥을 많은",
        "startMs": 1920,
        "durationMs": 4120,
        "language": "ko"
      },
      {
        "lineIndex": 2,
        "text": "기술이 부족해서라고 생각을",
        "startMs": 4279,
        "durationMs": 3721,
        "language": "ko"
      },
      {
        "lineIndex": 3,
        "text": "하시는데요. 자, 진짜 이유는 밥",
        "startMs": 6040,
        "durationMs": 4519,
        "language": "ko"
      },
      {
        "lineIndex": 4,
        "text": "지을 때부터 결정됩니다. 먼저 중요한",
        "startMs": 8000,
        "durationMs": 4799,
        "language": "ko"
      },
      {
        "lineIndex": 5,
        "text": "밥부터 지어 볼게요.",
        "startMs": 10559,
        "durationMs": 4921,
        "language": "ko"
      },
      {
        "lineIndex": 6,
        "text": "먼저 김밥은 고슬고슬하게 지어야지 잘",
        "startMs": 12799,
        "durationMs": 6721,
        "language": "ko"
      },
      {
        "lineIndex": 7,
        "text": "펴지는데요. 자, 불린살",
        "startMs": 15480,
        "durationMs": 8280,
        "language": "ko"
      },
      {
        "lineIndex": 8,
        "text": "세 컵. 그리고 물.",
        "startMs": 19520,
        "durationMs": 7960,
        "language": "ko"
      },
      {
        "lineIndex": 9,
        "text": "물색 동양으로 넣어 주시고요.",
        "startMs": 23760,
        "durationMs": 6240,
        "language": "ko"
      },
      {
        "lineIndex": 10,
        "text": "자, 여기서 맛집 비법인데요. 소금",
        "startMs": 27480,
        "durationMs": 5239,
        "language": "ko"
      },
      {
        "lineIndex": 11,
        "text": "한 숟가락을 넣어 주세요.",
        "startMs": 30000,
        "durationMs": 5239,
        "language": "ko"
      },
      {
        "lineIndex": 12,
        "text": "자, 김밥을 지을 때이 소금을 놓고",
        "startMs": 32719,
        "durationMs": 5360,
        "language": "ko"
      },
      {
        "lineIndex": 13,
        "text": "지으면 간도 되지만요 중요한 포인트는",
        "startMs": 35239,
        "durationMs": 5561,
        "language": "ko"
      },
      {
        "lineIndex": 14,
        "text": "바알발이 덜퍼지고 식감이 탱글탱글하게",
        "startMs": 38079,
        "durationMs": 5241,
        "language": "ko"
      },
      {
        "lineIndex": 15,
        "text": "살아납니다. 잘 섞어 주신 다음에",
        "startMs": 40800,
        "durationMs": 5040,
        "language": "ko"
      },
      {
        "lineIndex": 16,
        "text": "밥을 지어 주세요.",
        "startMs": 43320,
        "durationMs": 4040,
        "language": "ko"
      },
      {
        "lineIndex": 17,
        "text": "자, 밥이 다 됐으면 뜨거울 [음악]",
        "startMs": 45840,
        "durationMs": 4160,
        "language": "ko"
      },
      {
        "lineIndex": 18,
        "text": "때 바로 맛소금,",
        "startMs": 47360,
        "durationMs": 5640,
        "language": "ko"
      },
      {
        "lineIndex": 19,
        "text": "참기름,",
        "startMs": 50000,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 20,
        "text": "그리고 깨",
        "startMs": 53039,
        "durationMs": 5801,
        "language": "ko"
      },
      {
        "lineIndex": 21,
        "text": "넣고 간을 해 주세요. 자, 많은",
        "startMs": 56399,
        "durationMs": 4761,
        "language": "ko"
      },
      {
        "lineIndex": 22,
        "text": "분들이 뜨거우니까 밥을 씻킨 뒤에",
        "startMs": 58840,
        "durationMs": 4719,
        "language": "ko"
      },
      {
        "lineIndex": 23,
        "text": "간을 하시는데요.이 식은 밥에 간을",
        "startMs": 61160,
        "durationMs": 4600,
        "language": "ko"
      },
      {
        "lineIndex": 24,
        "text": "하면 간이 속까지 들어가지 않고이",
        "startMs": 63559,
        "durationMs": 4761,
        "language": "ko"
      },
      {
        "lineIndex": 25,
        "text": "겉에만 묻어서 훨씬 작게 느껴집니다.",
        "startMs": 65760,
        "durationMs": 4280,
        "language": "ko"
      },
      {
        "lineIndex": 26,
        "text": "자, 꼭 뜨거울 때 간을 해야지",
        "startMs": 68320,
        "durationMs": 5400,
        "language": "ko"
      },
      {
        "lineIndex": 27,
        "text": "속까지 간이 골고루해요.",
        "startMs": 70040,
        "durationMs": 5399,
        "language": "ko"
      },
      {
        "lineIndex": 28,
        "text": "자, 간늘 한 뒤에 한 숟가락 드셔",
        "startMs": 73720,
        "durationMs": 4600,
        "language": "ko"
      },
      {
        "lineIndex": 29,
        "text": "보시고요.",
        "startMs": 75439,
        "durationMs": 5401,
        "language": "ko"
      },
      {
        "lineIndex": 30,
        "text": "조금 심심한데 싶을 정도로만 간을대",
        "startMs": 78320,
        "durationMs": 4799,
        "language": "ko"
      },
      {
        "lineIndex": 31,
        "text": "주세요. 이게 나중에 식으면 간이",
        "startMs": 80840,
        "durationMs": 4639,
        "language": "ko"
      },
      {
        "lineIndex": 32,
        "text": "훨씬 더 세지거든요.",
        "startMs": 83119,
        "durationMs": 3521,
        "language": "ko"
      },
      {
        "lineIndex": 33,
        "text": "자, 이제 여기서 핵심",
        "startMs": 85479,
        "durationMs": 3881,
        "language": "ko"
      },
      {
        "lineIndex": 34,
        "text": "포인트입니다.이 김밥이 터지는 가장",
        "startMs": 86640,
        "durationMs": 4880,
        "language": "ko"
      },
      {
        "lineIndex": 35,
        "text": "큰 이유 중 하나가 여기 있는데요.",
        "startMs": 89360,
        "durationMs": 4360,
        "language": "ko"
      },
      {
        "lineIndex": 36,
        "text": "바로 밥에 김을 날리지 않고 바로",
        "startMs": 91520,
        "durationMs": 3760,
        "language": "ko"
      },
      {
        "lineIndex": 37,
        "text": "사용해서입니다.",
        "startMs": 93720,
        "durationMs": 3640,
        "language": "ko"
      },
      {
        "lineIndex": 38,
        "text": "자, 밥이 뜨거울 때 김에 올리면",
        "startMs": 95280,
        "durationMs": 4799,
        "language": "ko"
      },
      {
        "lineIndex": 39,
        "text": "김이 확 쪼그라들고 눅눅해져서 쉽게",
        "startMs": 97360,
        "durationMs": 5480,
        "language": "ko"
      },
      {
        "lineIndex": 40,
        "text": "찢어집니다. 그렇기 때문에 밥에 김을",
        "startMs": 100079,
        "durationMs": 4680,
        "language": "ko"
      },
      {
        "lineIndex": 41,
        "text": "완전히 날리면서 시켜 주는게",
        "startMs": 102840,
        "durationMs": 4440,
        "language": "ko"
      },
      {
        "lineIndex": 42,
        "text": "포인트예요. 자, 여기서 차갑게",
        "startMs": 104759,
        "durationMs": 4960,
        "language": "ko"
      },
      {
        "lineIndex": 43,
        "text": "시키는게 아니라 따뜻할 정도로만 시켜",
        "startMs": 107280,
        "durationMs": 4799,
        "language": "ko"
      },
      {
        "lineIndex": 44,
        "text": "주세요.",
        "startMs": 109719,
        "durationMs": 4561,
        "language": "ko"
      },
      {
        "lineIndex": 45,
        "text": "자, 이렇게 시킨 뒤에 김에 올리면",
        "startMs": 112079,
        "durationMs": 5241,
        "language": "ko"
      },
      {
        "lineIndex": 46,
        "text": "김밥이 확실히 덜 터집니다.",
        "startMs": 114280,
        "durationMs": 4960,
        "language": "ko"
      },
      {
        "lineIndex": 47,
        "text": "자, 그리고 이렇게 잘 시켜 놓은",
        "startMs": 117320,
        "durationMs": 4360,
        "language": "ko"
      },
      {
        "lineIndex": 48,
        "text": "밥을 밥솥에 놓고 보온을 하면 다시",
        "startMs": 119240,
        "durationMs": 5199,
        "language": "ko"
      },
      {
        "lineIndex": 49,
        "text": "뜨거워지니까 마르지 않게 밥솥에 놓고",
        "startMs": 121680,
        "durationMs": 6160,
        "language": "ko"
      },
      {
        "lineIndex": 50,
        "text": "코드는 꼭 뽑아 주세요.",
        "startMs": 124439,
        "durationMs": 5361,
        "language": "ko"
      },
      {
        "lineIndex": 51,
        "text": "자, 다음 계란 붙여 줄 건데요.이",
        "startMs": 127840,
        "durationMs": 4360,
        "language": "ko"
      },
      {
        "lineIndex": 52,
        "text": "이 계란마리로 어렵게 만들지 마시고",
        "startMs": 129800,
        "durationMs": 4600,
        "language": "ko"
      },
      {
        "lineIndex": 53,
        "text": "이렇게 만들면 쉬워요. 먼저 볼에",
        "startMs": 132200,
        "durationMs": 5960,
        "language": "ko"
      },
      {
        "lineIndex": 54,
        "text": "계란 일곱 개를 깨 주시고요.",
        "startMs": 134400,
        "durationMs": 5199,
        "language": "ko"
      },
      {
        "lineIndex": 55,
        "text": "자, 여기에 소금관을 살짝 해",
        "startMs": 138160,
        "durationMs": 3799,
        "language": "ko"
      },
      {
        "lineIndex": 56,
        "text": "주시고요.",
        "startMs": 139599,
        "durationMs": 4321,
        "language": "ko"
      },
      {
        "lineIndex": 57,
        "text": "다음으로 거품이 나지 않게 잘어",
        "startMs": 141959,
        "durationMs": 4961,
        "language": "ko"
      },
      {
        "lineIndex": 58,
        "text": "주세요.",
        "startMs": 143920,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 59,
        "text": "자, 이제 프라이팬 꺼내 주시고",
        "startMs": 147879,
        "durationMs": 6681,
        "language": "ko"
      },
      {
        "lineIndex": 60,
        "text": "기름을 아주 얇게 발라 주세요.",
        "startMs": 150120,
        "durationMs": 6720,
        "language": "ko"
      },
      {
        "lineIndex": 61,
        "text": "자, 계란 지은 기름을 조금만 많이",
        "startMs": 154560,
        "durationMs": 4800,
        "language": "ko"
      },
      {
        "lineIndex": 62,
        "text": "넣어도 계란 후라이처럼 튀겨지거든요.",
        "startMs": 156840,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 63,
        "text": "자, 그래서 아주 얇게 발라 주시고",
        "startMs": 159360,
        "durationMs": 5480,
        "language": "ko"
      },
      {
        "lineIndex": 64,
        "text": "자, 불은 꼭 약불로 올려 주세요.",
        "startMs": 161840,
        "durationMs": 4240,
        "language": "ko"
      },
      {
        "lineIndex": 65,
        "text": "자, 이제 예열이 됐으면 이제",
        "startMs": 164840,
        "durationMs": 5319,
        "language": "ko"
      },
      {
        "lineIndex": 66,
        "text": "계란물을 다 부어 주세요.",
        "startMs": 166080,
        "durationMs": 4079,
        "language": "ko"
      },
      {
        "lineIndex": 67,
        "text": "자, 그리고 여기서 뚜껑을 덮은 다음",
        "startMs": 171560,
        "durationMs": 5880,
        "language": "ko"
      },
      {
        "lineIndex": 68,
        "text": "이대로 한 70% 정도 익혀 줄게요.",
        "startMs": 174159,
        "durationMs": 5681,
        "language": "ko"
      },
      {
        "lineIndex": 69,
        "text": "자, 여기서 센불로 구우면 윗부분은",
        "startMs": 177440,
        "durationMs": 4760,
        "language": "ko"
      },
      {
        "lineIndex": 70,
        "text": "타고 속은 안 익습니다. 그러니까 꼭",
        "startMs": 179840,
        "durationMs": 5119,
        "language": "ko"
      },
      {
        "lineIndex": 71,
        "text": "약불로 익혀 주셔야 돼요.",
        "startMs": 182200,
        "durationMs": 6319,
        "language": "ko"
      },
      {
        "lineIndex": 72,
        "text": "자, 이제 한 3분 정도 익혔는데요.",
        "startMs": 184959,
        "durationMs": 5161,
        "language": "ko"
      },
      {
        "lineIndex": 73,
        "text": "자, 이제 보시면 이렇게 계란물이",
        "startMs": 188519,
        "durationMs": 4121,
        "language": "ko"
      },
      {
        "lineIndex": 74,
        "text": "익어서 이제 흐르지 않죠? 자, 이때",
        "startMs": 190120,
        "durationMs": 5520,
        "language": "ko"
      },
      {
        "lineIndex": 75,
        "text": "뒤집어서",
        "startMs": 192640,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 76,
        "text": "뒷부분은 살짝만 더 익혀 주세요.",
        "startMs": 195720,
        "durationMs": 5640,
        "language": "ko"
      },
      {
        "lineIndex": 77,
        "text": "자, 이렇게 만들면 계란 지단을 쉽고",
        "startMs": 198879,
        "durationMs": 4920,
        "language": "ko"
      },
      {
        "lineIndex": 78,
        "text": "깔끔하게 만들 수 있습니다. 자,이",
        "startMs": 201360,
        "durationMs": 5040,
        "language": "ko"
      },
      {
        "lineIndex": 79,
        "text": "계란을 한김시켜 준 다음 단무지 하나",
        "startMs": 203799,
        "durationMs": 4561,
        "language": "ko"
      },
      {
        "lineIndex": 80,
        "text": "올려 보시고요.요",
        "startMs": 206400,
        "durationMs": 5600,
        "language": "ko"
      },
      {
        "lineIndex": 81,
        "text": "단무지 길이대로",
        "startMs": 208360,
        "durationMs": 3640,
        "language": "ko"
      },
      {
        "lineIndex": 82,
        "text": "자,이 단무지 길이로 잘라 주세요.",
        "startMs": 212080,
        "durationMs": 4439,
        "language": "ko"
      },
      {
        "lineIndex": 83,
        "text": "자, 다음으로 오인데요. 자,",
        "startMs": 218360,
        "durationMs": 4400,
        "language": "ko"
      },
      {
        "lineIndex": 84,
        "text": "김밥에서 가장 중요한 부분이 수분을",
        "startMs": 220439,
        "durationMs": 4360,
        "language": "ko"
      },
      {
        "lineIndex": 85,
        "text": "잘 잡아 주는 겁니다. 그래야 오래",
        "startMs": 222760,
        "durationMs": 3759,
        "language": "ko"
      },
      {
        "lineIndex": 86,
        "text": "두고 먹어도 눅눅하지 않고",
        "startMs": 224799,
        "durationMs": 4481,
        "language": "ko"
      },
      {
        "lineIndex": 87,
        "text": "깔끔하거든요. 자, 먼저 단무지",
        "startMs": 226519,
        "durationMs": 6080,
        "language": "ko"
      },
      {
        "lineIndex": 88,
        "text": "길이에 맞게",
        "startMs": 229280,
        "durationMs": 3319,
        "language": "ko"
      },
      {
        "lineIndex": 89,
        "text": "복지를 잘라내 주시고요. 자,",
        "startMs": 233120,
        "durationMs": 6679,
        "language": "ko"
      },
      {
        "lineIndex": 90,
        "text": "다음으로 4등분 해 주세요.",
        "startMs": 235680,
        "durationMs": 4119,
        "language": "ko"
      },
      {
        "lineIndex": 91,
        "text": "자, 그리고 보시면 OEC에 물이",
        "startMs": 242959,
        "durationMs": 4241,
        "language": "ko"
      },
      {
        "lineIndex": 92,
        "text": "많잖아요. 그래서 오이를 꼭 돌연내",
        "startMs": 244720,
        "durationMs": 5480,
        "language": "ko"
      },
      {
        "lineIndex": 93,
        "text": "주시고요.",
        "startMs": 247200,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 94,
        "text": "자, 이제 여기서 3등분 해 주세요.",
        "startMs": 250959,
        "durationMs": 5960,
        "language": "ko"
      },
      {
        "lineIndex": 95,
        "text": "자, 다음으로 한번 절여서 물도 빼고",
        "startMs": 254519,
        "durationMs": 4761,
        "language": "ko"
      },
      {
        "lineIndex": 96,
        "text": "맛도 더해 줄 거예요. 먼저 소금 한",
        "startMs": 256919,
        "durationMs": 4401,
        "language": "ko"
      },
      {
        "lineIndex": 97,
        "text": "숟가락.",
        "startMs": 259280,
        "durationMs": 4919,
        "language": "ko"
      },
      {
        "lineIndex": 98,
        "text": "다음 설탕 한 숟가락.",
        "startMs": 261320,
        "durationMs": 5920,
        "language": "ko"
      },
      {
        "lineIndex": 99,
        "text": "다음 식초 한 숟가락",
        "startMs": 264199,
        "durationMs": 6601,
        "language": "ko"
      },
      {
        "lineIndex": 100,
        "text": "넣고 잘 버무려 주시고요.",
        "startMs": 267240,
        "durationMs": 5280,
        "language": "ko"
      },
      {
        "lineIndex": 101,
        "text": "다음 바로 체망에 올려 주세요.",
        "startMs": 270800,
        "durationMs": 3720,
        "language": "ko"
      },
      {
        "lineIndex": 102,
        "text": "이렇게 하면 오이에 물도 빠지면서",
        "startMs": 272520,
        "durationMs": 4160,
        "language": "ko"
      },
      {
        "lineIndex": 103,
        "text": "자연스럽게 절여집니다. 자, 이대로",
        "startMs": 274520,
        "durationMs": 6080,
        "language": "ko"
      },
      {
        "lineIndex": 104,
        "text": "20분간 절여 줄게요.",
        "startMs": 276680,
        "durationMs": 6280,
        "language": "ko"
      },
      {
        "lineIndex": 105,
        "text": "자, 다음은 당근인데요.이 김밥",
        "startMs": 280600,
        "durationMs": 3840,
        "language": "ko"
      },
      {
        "lineIndex": 106,
        "text": "맛있는 집은이 당근을 [음악]",
        "startMs": 282960,
        "durationMs": 5120,
        "language": "ko"
      },
      {
        "lineIndex": 107,
        "text": "잘합니다. 보통 당근을 챘아",
        "startMs": 284440,
        "durationMs": 5640,
        "language": "ko"
      },
      {
        "lineIndex": 108,
        "text": "주는데요. 이렇게 해도 괜찮지만",
        "startMs": 288080,
        "durationMs": 4600,
        "language": "ko"
      },
      {
        "lineIndex": 109,
        "text": "당근의 맛과 식감이 반만 살아요.",
        "startMs": 290080,
        "durationMs": 4520,
        "language": "ko"
      },
      {
        "lineIndex": 110,
        "text": "자, 그래서 저는 당근 껍질 먼저",
        "startMs": 292680,
        "durationMs": 3880,
        "language": "ko"
      },
      {
        "lineIndex": 111,
        "text": "벗겨 주시고요. 자, 다음으로 채",
        "startMs": 294600,
        "durationMs": 5200,
        "language": "ko"
      },
      {
        "lineIndex": 112,
        "text": "썰어 주세요.",
        "startMs": 296560,
        "durationMs": 3240,
        "language": "ko"
      },
      {
        "lineIndex": 113,
        "text": "자, 다음 여기 소금 한 숟가락",
        "startMs": 300280,
        "durationMs": 6199,
        "language": "ko"
      },
      {
        "lineIndex": 114,
        "text": "그리고 물엿 두 숟가락을 넣고 잘",
        "startMs": 303280,
        "durationMs": 5639,
        "language": "ko"
      },
      {
        "lineIndex": 115,
        "text": "버무려 준 뒤에 자, 20분 정도",
        "startMs": 306479,
        "durationMs": 4720,
        "language": "ko"
      },
      {
        "lineIndex": 116,
        "text": "먼저 절여 줍니다. 이렇게 당근을",
        "startMs": 308919,
        "durationMs": 4174,
        "language": "ko"
      },
      {
        "lineIndex": 117,
        "text": "절인 뒤에 볶으면이 당근의 단맛이",
        "startMs": 311199,
        "durationMs": 4041,
        "language": "ko"
      },
      {
        "lineIndex": 118,
        "text": "[음악] 진해지고 식감이 훨씬",
        "startMs": 313093,
        "durationMs": 5267,
        "language": "ko"
      },
      {
        "lineIndex": 119,
        "text": "쫀득하면서 오독오독해집니다.",
        "startMs": 315240,
        "durationMs": 4880,
        "language": "ko"
      },
      {
        "lineIndex": 120,
        "text": "자, 20분이 지났으면 [음악] 이제",
        "startMs": 318360,
        "durationMs": 3440,
        "language": "ko"
      },
      {
        "lineIndex": 121,
        "text": "절인 당근을 물에 한번 헹궈",
        "startMs": 320120,
        "durationMs": 4680,
        "language": "ko"
      },
      {
        "lineIndex": 122,
        "text": "주시고요.",
        "startMs": 321800,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 123,
        "text": "그다음 물기를 꼭 짜 주세요. 바로",
        "startMs": 327120,
        "durationMs": 4840,
        "language": "ko"
      },
      {
        "lineIndex": 124,
        "text": "쓰면 이게 짤 수가 있어서 한번 씻어",
        "startMs": 329680,
        "durationMs": 4400,
        "language": "ko"
      },
      {
        "lineIndex": 125,
        "text": "주셔야 됩니다.",
        "startMs": 331960,
        "durationMs": 4440,
        "language": "ko"
      },
      {
        "lineIndex": 126,
        "text": "자, 이제 프라이팬에 기름 살짝 둘러",
        "startMs": 334080,
        "durationMs": 4920,
        "language": "ko"
      },
      {
        "lineIndex": 127,
        "text": "주시고요.",
        "startMs": 336400,
        "durationMs": 6680,
        "language": "ko"
      },
      {
        "lineIndex": 128,
        "text": "자, 예열이 됐으면 당근을 넣고",
        "startMs": 339000,
        "durationMs": 8840,
        "language": "ko"
      },
      {
        "lineIndex": 129,
        "text": "한 1분 정도만 빠르게 볶아 주세요.",
        "startMs": 343080,
        "durationMs": 4760,
        "language": "ko"
      },
      {
        "lineIndex": 130,
        "text": "자, 이렇게 당근을 볶으면이 김밥에",
        "startMs": 348160,
        "durationMs": 4720,
        "language": "ko"
      },
      {
        "lineIndex": 131,
        "text": "넣어도 맛있지만 솔직히 그냥 당근만",
        "startMs": 350479,
        "durationMs": 6280,
        "language": "ko"
      },
      {
        "lineIndex": 132,
        "text": "집어 먹어도 정말 [음악] 맛있어요.",
        "startMs": 352880,
        "durationMs": 6240,
        "language": "ko"
      },
      {
        "lineIndex": 133,
        "text": "자, 다음은 어묵인데요.이 어묵은",
        "startMs": 356759,
        "durationMs": 4160,
        "language": "ko"
      },
      {
        "lineIndex": 134,
        "text": "원래 어느 정도 간이 되어 있기",
        "startMs": 359120,
        "durationMs": 4040,
        "language": "ko"
      },
      {
        "lineIndex": 135,
        "text": "때문에 간장을 너무 많이 넣을 필요는",
        "startMs": 360919,
        "durationMs": 5280,
        "language": "ko"
      },
      {
        "lineIndex": 136,
        "text": "없습니다. 먼저 어묵 일곱 장을 얇게",
        "startMs": 363160,
        "durationMs": 6319,
        "language": "ko"
      },
      {
        "lineIndex": 137,
        "text": "채썰어 주시고요.",
        "startMs": 366199,
        "durationMs": 5761,
        "language": "ko"
      },
      {
        "lineIndex": 138,
        "text": "자, 프라이팬에 넣고",
        "startMs": 369479,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 139,
        "text": "진간장 한 숟가락.",
        "startMs": 371960,
        "durationMs": 5359,
        "language": "ko"
      },
      {
        "lineIndex": 140,
        "text": "자, 물엿 두 숟가락.",
        "startMs": 374479,
        "durationMs": 5081,
        "language": "ko"
      },
      {
        "lineIndex": 141,
        "text": "자, 여기서 중요한 포인트는 여기에",
        "startMs": 377319,
        "durationMs": 5681,
        "language": "ko"
      },
      {
        "lineIndex": 142,
        "text": "물을 두 숟가락 넣어 주세요.",
        "startMs": 379560,
        "durationMs": 5320,
        "language": "ko"
      },
      {
        "lineIndex": 143,
        "text": "자, 물을 안 넣고 볶으면 어묵이",
        "startMs": 383000,
        "durationMs": 4560,
        "language": "ko"
      },
      {
        "lineIndex": 144,
        "text": "뻣뻣하고 질겨지는데요.이 물을 넣고",
        "startMs": 384880,
        "durationMs": 4480,
        "language": "ko"
      },
      {
        "lineIndex": 145,
        "text": "볶으면 식감이 쫄깃하면서",
        "startMs": 387560,
        "durationMs": 4189,
        "language": "ko"
      },
      {
        "lineIndex": 146,
        "text": "부드러워집니다. [음악]",
        "startMs": 389360,
        "durationMs": 2389,
        "language": "ko"
      },
      {
        "lineIndex": 147,
        "text": "자, 어묵이 부들부들 부드러워질",
        "startMs": 392199,
        "durationMs": 5560,
        "language": "ko"
      },
      {
        "lineIndex": 148,
        "text": "때까지 익혀 주시고요.",
        "startMs": 394039,
        "durationMs": 3720,
        "language": "ko"
      },
      {
        "lineIndex": 149,
        "text": "자, 다음으로 햄인데요.이 햄은 꼭",
        "startMs": 401560,
        "durationMs": 4960,
        "language": "ko"
      },
      {
        "lineIndex": 150,
        "text": "한번 볶아서 사용해 주세요. 자,",
        "startMs": 403880,
        "durationMs": 4879,
        "language": "ko"
      },
      {
        "lineIndex": 151,
        "text": "봉지를 뜯으면 이렇게 물이 꽤 많이",
        "startMs": 406520,
        "durationMs": 4720,
        "language": "ko"
      },
      {
        "lineIndex": 152,
        "text": "나오는데요.이 상태로 김밥에 바로",
        "startMs": 408759,
        "durationMs": 5521,
        "language": "ko"
      },
      {
        "lineIndex": 153,
        "text": "넣으면 맛도하고 또 빨리 쉬어요.",
        "startMs": 411240,
        "durationMs": 4639,
        "language": "ko"
      },
      {
        "lineIndex": 154,
        "text": "자, 먼저 단무지 크기로 썰어",
        "startMs": 414280,
        "durationMs": 4599,
        "language": "ko"
      },
      {
        "lineIndex": 155,
        "text": "주시고요.",
        "startMs": 415879,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 156,
        "text": "자, 볶클 때 포인트는 프라이팬에",
        "startMs": 420680,
        "durationMs": 4480,
        "language": "ko"
      },
      {
        "lineIndex": 157,
        "text": "기름을 두르지 말고 중약불로 올린",
        "startMs": 422759,
        "durationMs": 5560,
        "language": "ko"
      },
      {
        "lineIndex": 158,
        "text": "다음에 햄을 넣어 주시고요.요",
        "startMs": 425160,
        "durationMs": 4879,
        "language": "ko"
      },
      {
        "lineIndex": 159,
        "text": "겉에 있는 수분을 날려 준다",
        "startMs": 428319,
        "durationMs": 4121,
        "language": "ko"
      },
      {
        "lineIndex": 160,
        "text": "생각하시고 볶아 주세요.이 이 기름을",
        "startMs": 430039,
        "durationMs": 4600,
        "language": "ko"
      },
      {
        "lineIndex": 161,
        "text": "안 둘렀기 때문에 불이 세면 또 탈",
        "startMs": 432440,
        "durationMs": 4920,
        "language": "ko"
      },
      {
        "lineIndex": 162,
        "text": "수가 있어요. 중약불로 천천히 익혀",
        "startMs": 434639,
        "durationMs": 5721,
        "language": "ko"
      },
      {
        "lineIndex": 163,
        "text": "주세요.",
        "startMs": 437360,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 164,
        "text": "자, 다음은 단무지와 우엉데요.이",
        "startMs": 442599,
        "durationMs": 5440,
        "language": "ko"
      },
      {
        "lineIndex": 165,
        "text": "판용 단무지와 우엉은 맛과 향이 엄청",
        "startMs": 445319,
        "durationMs": 5241,
        "language": "ko"
      },
      {
        "lineIndex": 166,
        "text": "강합니다. 그래서 그냥 넣으면이",
        "startMs": 448039,
        "durationMs": 4840,
        "language": "ko"
      },
      {
        "lineIndex": 167,
        "text": "김밥을 먹었을 때이 단무심맛밖에 안",
        "startMs": 450560,
        "durationMs": 4359,
        "language": "ko"
      },
      {
        "lineIndex": 168,
        "text": "나는 경우도 있어요. 그래서 저는",
        "startMs": 452879,
        "durationMs": 6481,
        "language": "ko"
      },
      {
        "lineIndex": 169,
        "text": "물에 한번 가볍게 씻어서 사용합니다.",
        "startMs": 454919,
        "durationMs": 4441,
        "language": "ko"
      },
      {
        "lineIndex": 170,
        "text": "자, 이제 김밥의 하이라이트죠.",
        "startMs": 463720,
        "durationMs": 4560,
        "language": "ko"
      },
      {
        "lineIndex": 171,
        "text": "김밥을 말아 줄 건데요.이 김밥이",
        "startMs": 465840,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 172,
        "text": "터지는 이유가 첫 번째 밥이 뜨거워서",
        "startMs": 468280,
        "durationMs": 5080,
        "language": "ko"
      },
      {
        "lineIndex": 173,
        "text": "김이 터지는 경우가 있고요. 두 번째",
        "startMs": 470840,
        "durationMs": 5120,
        "language": "ko"
      },
      {
        "lineIndex": 174,
        "text": "김밥을 헐렁하게 말아서 썰 터지는",
        "startMs": 473360,
        "durationMs": 4640,
        "language": "ko"
      },
      {
        "lineIndex": 175,
        "text": "경우가 [음악] 있습니다. 자, 썰",
        "startMs": 475960,
        "durationMs": 4199,
        "language": "ko"
      },
      {
        "lineIndex": 176,
        "text": "터지지 않게 단단하게 많은 포인트",
        "startMs": 478000,
        "durationMs": 5039,
        "language": "ko"
      },
      {
        "lineIndex": 177,
        "text": "알려 드릴게요. 자, 첫 번째 김에",
        "startMs": 480159,
        "durationMs": 4921,
        "language": "ko"
      },
      {
        "lineIndex": 178,
        "text": "맨들맨들한 면이 바닥으로 가게",
        "startMs": 483039,
        "durationMs": 4481,
        "language": "ko"
      },
      {
        "lineIndex": 179,
        "text": "두시고요. 그리고 이렇게 김을 세로",
        "startMs": 485080,
        "durationMs": 5399,
        "language": "ko"
      },
      {
        "lineIndex": 180,
        "text": "방향으로 두세요.이 이 가로 방향으로",
        "startMs": 487520,
        "durationMs": 5720,
        "language": "ko"
      },
      {
        "lineIndex": 181,
        "text": "김밥을 말면요 위아래 길이가 짧아서",
        "startMs": 490479,
        "durationMs": 6000,
        "language": "ko"
      },
      {
        "lineIndex": 182,
        "text": "생각보다 단단하게 말기가 어렵습니다.",
        "startMs": 493240,
        "durationMs": 5679,
        "language": "ko"
      },
      {
        "lineIndex": 183,
        "text": "자, 두 번째 밥을 한 공기 올리고",
        "startMs": 496479,
        "durationMs": 5280,
        "language": "ko"
      },
      {
        "lineIndex": 184,
        "text": "얇게 펴 주시는데요. 자, 김의 좌우",
        "startMs": 498919,
        "durationMs": 5761,
        "language": "ko"
      },
      {
        "lineIndex": 185,
        "text": "양쪽 끝까지 골고루 펼쳐 주세요.이",
        "startMs": 501759,
        "durationMs": 5241,
        "language": "ko"
      },
      {
        "lineIndex": 186,
        "text": "꼭지 부분이 항상 터지는 이유가이",
        "startMs": 504680,
        "durationMs": 3880,
        "language": "ko"
      },
      {
        "lineIndex": 187,
        "text": "밥을 끝까지 펴 주지 않아서",
        "startMs": 507000,
        "durationMs": 3879,
        "language": "ko"
      },
      {
        "lineIndex": 188,
        "text": "그렇거든요. 그렇기 때문에 이렇게",
        "startMs": 508560,
        "durationMs": 4599,
        "language": "ko"
      },
      {
        "lineIndex": 189,
        "text": "끝까지 잘 펴 주신 다음에 위에는",
        "startMs": 510879,
        "durationMs": 5520,
        "language": "ko"
      },
      {
        "lineIndex": 190,
        "text": "손가락 두 마디 정도 남겨 주세요.",
        "startMs": 513159,
        "durationMs": 5201,
        "language": "ko"
      },
      {
        "lineIndex": 191,
        "text": "자, 세 번째로 재료를 올릴 때는",
        "startMs": 516399,
        "durationMs": 4640,
        "language": "ko"
      },
      {
        "lineIndex": 192,
        "text": "색이 겹치지 않게 시안껏 올려 주시면",
        "startMs": 518360,
        "durationMs": 5679,
        "language": "ko"
      },
      {
        "lineIndex": 193,
        "text": "되는데요.",
        "startMs": 521039,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 194,
        "text": "자, 여기서 포인트는 밥의 양쪽",
        "startMs": 527440,
        "durationMs": 4200,
        "language": "ko"
      },
      {
        "lineIndex": 195,
        "text": "끝부분이 보이도록 재료를 올려",
        "startMs": 529720,
        "durationMs": 4600,
        "language": "ko"
      },
      {
        "lineIndex": 196,
        "text": "주세요. 이게 나중에 말고 나면이 밥",
        "startMs": 531640,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 197,
        "text": "밖으로 재료가 튀어나와 있는 경우가",
        "startMs": 534320,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 198,
        "text": "있는데이 밑에 밥과 위에 밥이 만나지",
        "startMs": 536640,
        "durationMs": 5040,
        "language": "ko"
      },
      {
        "lineIndex": 199,
        "text": "못해서 그렇습니다. 그렇기 때문에",
        "startMs": 539320,
        "durationMs": 4600,
        "language": "ko"
      },
      {
        "lineIndex": 200,
        "text": "너무 욕심 부리지 말고 밥이 만날 수",
        "startMs": 541680,
        "durationMs": 5640,
        "language": "ko"
      },
      {
        "lineIndex": 201,
        "text": "있는요 공간을 남겨 두세요. 자,네",
        "startMs": 543920,
        "durationMs": 7120,
        "language": "ko"
      },
      {
        "lineIndex": 202,
        "text": "번째. 이제 말 때는 밑부분을 들어서",
        "startMs": 547320,
        "durationMs": 6600,
        "language": "ko"
      },
      {
        "lineIndex": 203,
        "text": "재료를 완전히 감싸 주세요.",
        "startMs": 551040,
        "durationMs": 6000,
        "language": "ko"
      },
      {
        "lineIndex": 204,
        "text": "자, 그리고 좌우부터 중간으로 안으로",
        "startMs": 553920,
        "durationMs": 6400,
        "language": "ko"
      },
      {
        "lineIndex": 205,
        "text": "말아 주시고요.",
        "startMs": 557040,
        "durationMs": 3280,
        "language": "ko"
      },
      {
        "lineIndex": 206,
        "text": "당겨서 한 번 더 말아 주시고 당겨서",
        "startMs": 560360,
        "durationMs": 4840,
        "language": "ko"
      },
      {
        "lineIndex": 207,
        "text": "한 번 더 말아 주세요. 자, 이걸",
        "startMs": 562880,
        "durationMs": 4639,
        "language": "ko"
      },
      {
        "lineIndex": 208,
        "text": "그냥 쭉 말면 헐렁해서 썰면 다",
        "startMs": 565200,
        "durationMs": 4400,
        "language": "ko"
      },
      {
        "lineIndex": 209,
        "text": "터집니다. 그래서이 과정이 정말",
        "startMs": 567519,
        "durationMs": 4201,
        "language": "ko"
      },
      {
        "lineIndex": 210,
        "text": "중요해요. 자, 이렇게 단단하게",
        "startMs": 569600,
        "durationMs": 4960,
        "language": "ko"
      },
      {
        "lineIndex": 211,
        "text": "말렸으면 이제",
        "startMs": 571720,
        "durationMs": 5559,
        "language": "ko"
      },
      {
        "lineIndex": 212,
        "text": "김에 물을 살짝 묻혀 주신 다음에",
        "startMs": 574560,
        "durationMs": 4719,
        "language": "ko"
      },
      {
        "lineIndex": 213,
        "text": "김의 끝부분이 바닥을 보게 놓아",
        "startMs": 577279,
        "durationMs": 6761,
        "language": "ko"
      },
      {
        "lineIndex": 214,
        "text": "두셔야 썰이 풀리지가 않아요.",
        "startMs": 579279,
        "durationMs": 4761,
        "language": "ko"
      },
      {
        "lineIndex": 215,
        "text": "자, 말았으면 장갑에 참기름 묻히고",
        "startMs": 584120,
        "durationMs": 6520,
        "language": "ko"
      },
      {
        "lineIndex": 216,
        "text": "위에 한번 발라 주시고요.",
        "startMs": 586640,
        "durationMs": 4000,
        "language": "ko"
      },
      {
        "lineIndex": 217,
        "text": "자, 김밥을 이렇게 단단하게",
        "startMs": 590720,
        "durationMs": 3880,
        "language": "ko"
      },
      {
        "lineIndex": 218,
        "text": "말아주면이 칼에 기름 바르지 않아도",
        "startMs": 592160,
        "durationMs": 6880,
        "language": "ko"
      },
      {
        "lineIndex": 219,
        "text": "터지지 않고 깔끔하게 잘 썰립니다.",
        "startMs": 594600,
        "durationMs": 4440,
        "language": "ko"
      },
      {
        "lineIndex": 220,
        "text": "자, 이렇게 단단하게 말면 꼬다리도",
        "startMs": 601440,
        "durationMs": 6440,
        "language": "ko"
      },
      {
        "lineIndex": 221,
        "text": "터지는 거 없이 예쁘게 잘 잘립니다.",
        "startMs": 603480,
        "durationMs": 6200,
        "language": "ko"
      },
      {
        "lineIndex": 222,
        "text": "자, 오늘 김밥의 가장 중요한",
        "startMs": 607880,
        "durationMs": 4320,
        "language": "ko"
      },
      {
        "lineIndex": 223,
        "text": "포인트는 온도와 수분을 잘 잡아 주는",
        "startMs": 609680,
        "durationMs": 4640,
        "language": "ko"
      },
      {
        "lineIndex": 224,
        "text": "겁니다. 자,이 두 가지만 기억하셔도",
        "startMs": 612200,
        "durationMs": 4280,
        "language": "ko"
      },
      {
        "lineIndex": 225,
        "text": "김밥이 터지지 않고 오래 두고 먹어도",
        "startMs": 614320,
        "durationMs": 4560,
        "language": "ko"
      },
      {
        "lineIndex": 226,
        "text": "맛있게 드실 수 있어요. 자, 오늘도",
        "startMs": 616480,
        "durationMs": 4080,
        "language": "ko"
      },
      {
        "lineIndex": 227,
        "text": "시청해 주셔서 감사합니다. 다음에 또",
        "startMs": 618880,
        "durationMs": 3240,
        "language": "ko"
      },
      {
        "lineIndex": 228,
        "text": "유익한 영상으로 찾아뵙도록",
        "startMs": 620560,
        "durationMs": 3719,
        "language": "ko"
      },
      {
        "lineIndex": 229,
        "text": "하겠습니다.",
        "startMs": 622120,
        "durationMs": 2159,
        "language": "ko"
      }
    ],
