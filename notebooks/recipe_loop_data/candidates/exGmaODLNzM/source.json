    "segments": [
      {
        "lineIndex": 0,
        "text": "오븐이 있어야지만 가능한 요리인 줄",
        "startMs": 599,
        "durationMs": 4841,
        "language": "ko"
      },
      {
        "lineIndex": 1,
        "text": "알았는데 오븐 없이 만들어도 너무",
        "startMs": 2879,
        "durationMs": 5241,
        "language": "ko"
      },
      {
        "lineIndex": 2,
        "text": "맛있어서 자주 해 먹고 있어요 채소",
        "startMs": 5440,
        "durationMs": 5440,
        "language": "ko"
      },
      {
        "lineIndex": 3,
        "text": "잘 안 먹는 일곱살 딸도 라따뚜이에",
        "startMs": 8120,
        "durationMs": 5399,
        "language": "ko"
      },
      {
        "lineIndex": 4,
        "text": "들어가는 건 편식 없이 잘 먹더라고요",
        "startMs": 10880,
        "durationMs": 5800,
        "language": "ko"
      },
      {
        "lineIndex": 5,
        "text": "올리브유 두름 팬에 다진마늘 양파",
        "startMs": 13519,
        "durationMs": 5600,
        "language": "ko"
      },
      {
        "lineIndex": 6,
        "text": "고기 넣어 볶다가 고기가 어느 정도",
        "startMs": 16680,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 7,
        "text": "익으면 토마토 소스를 넣어 주세요",
        "startMs": 19119,
        "durationMs": 5080,
        "language": "ko"
      },
      {
        "lineIndex": 8,
        "text": "소스와 야채를 잘 섞은 다음 불을",
        "startMs": 21680,
        "durationMs": 5120,
        "language": "ko"
      },
      {
        "lineIndex": 9,
        "text": "잠시 꺼두고 준비해 둔 호박 가지",
        "startMs": 24199,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 10,
        "text": "토마토를 둥글게 올려 주세요 치즈도",
        "startMs": 26800,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 11,
        "text": "듬뿍 넣어서 불 다시 올리고 소스가",
        "startMs": 29199,
        "durationMs": 5641,
        "language": "ko"
      },
      {
        "lineIndex": 12,
        "text": "끓으면 약불로 15분에서 20분 와",
        "startMs": 31800,
        "durationMs": 5680,
        "language": "ko"
      },
      {
        "lineIndex": 13,
        "text": "이거 이거 간단한데 정말 맛있어요",
        "startMs": 34840,
        "durationMs": 5280,
        "language": "ko"
      },
      {
        "lineIndex": 14,
        "text": "국물반 바삭하게 구워서 같이 먹으면",
        "startMs": 37480,
        "durationMs": 4720,
        "language": "ko"
      },
      {
        "lineIndex": 15,
