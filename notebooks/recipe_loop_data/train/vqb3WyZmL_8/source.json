        "startMs": 82480,
        "durationMs": 2000,
        "language": "ko"
      },
      {
        "lineIndex": 34,
        "text": "생표고버섯 세계 사용하겠습니다",
        "startMs": 84960,
        "durationMs": 4070,
        "language": "ko"
      },
      {
        "lineIndex": 35,
