    "segments": [
      {
        "lineIndex": 0,
        "text": "돼지 돈 드치게 할 건데이 갈비 살미",
        "startMs": 8480,
        "durationMs": 4560,
        "language": "ko"
      },
      {
        "lineIndex": 1,
        "text": "대패부이거든.이",
        "startMs": 11519,
        "durationMs": 3761,
        "language": "ko"
      },
      {
        "lineIndex": 2,
        "text": "돼지와 옆구리에 갈비 살및 대패",
        "startMs": 13040,
        "durationMs": 3560,
        "language": "ko"
      },
      {
        "lineIndex": 3,
        "text": "그 부분이 이게 되게 맛있다",
        "startMs": 15280,
        "durationMs": 3120,
        "language": "ko"
      },
      {
        "lineIndex": 4,
        "text": "하더라고. 고기 좋아하는 사람은이",
        "startMs": 16600,
        "durationMs": 3839,
        "language": "ko"
      },
      {
        "lineIndex": 5,
        "text": "고기를 좋아한다 하돼. 그런데 이제",
        "startMs": 18400,
        "durationMs": 4160,
        "language": "ko"
      },
      {
        "lineIndex": 6,
        "text": "돼지 앞다리 전지 아니 있나? 전지도",
        "startMs": 20439,
        "durationMs": 4321,
        "language": "ko"
      },
      {
        "lineIndex": 7,
        "text": "되고 삼겹도 되고 오급도 다 돼.",
        "startMs": 22560,
        "durationMs": 3719,
        "language": "ko"
      },
      {
        "lineIndex": 8,
        "text": "근데이 고기가 맛있다 해서 내가이",
        "startMs": 24760,
        "durationMs": 4080,
        "language": "ko"
      },
      {
        "lineIndex": 9,
        "text": "고기를 샀거든. 그래 그거 아니냐면",
        "startMs": 26279,
        "durationMs": 4801,
        "language": "ko"
      },
      {
        "lineIndex": 10,
        "text": "전지도 비계가 붙은 게야 되거든.",
        "startMs": 28840,
        "durationMs": 3640,
        "language": "ko"
      },
      {
        "lineIndex": 11,
        "text": "비계가 붙어야 돼. 전지가 살이",
        "startMs": 31080,
        "durationMs": 2999,
        "language": "ko"
      },
      {
        "lineIndex": 12,
        "text": "퍼썩하거든.",
        "startMs": 32480,
        "durationMs": 3320,
        "language": "ko"
      },
      {
        "lineIndex": 13,
        "text": "이거 따로 뭐 핏물은",
        "startMs": 34079,
        "durationMs": 3160,
        "language": "ko"
      },
      {
        "lineIndex": 14,
        "text": "근데 이거는 핏물 빼면 안 돼. 이거",
        "startMs": 35800,
        "durationMs": 3160,
        "language": "ko"
      },
      {
        "lineIndex": 15,
        "text": "뭐 물에 담가 놓으면 허해 갖고",
        "startMs": 37239,
        "durationMs": 2921,
        "language": "ko"
      },
      {
        "lineIndex": 16,
        "text": "걸려야 돼 못 쓴다.",
        "startMs": 38960,
        "durationMs": 4160,
        "language": "ko"
      },
      {
        "lineIndex": 17,
        "text": "아 그럼 바로 그냥 핏 치킨 다로 좀",
        "startMs": 40160,
        "durationMs": 3320,
        "language": "ko"
      },
      {
        "lineIndex": 18,
        "text": "닦아 가지고",
        "startMs": 43120,
        "durationMs": 2320,
        "language": "ko"
      },
      {
        "lineIndex": 19,
        "text": "그 그래 키친다 딱 그것도 없다이 딱",
        "startMs": 43480,
        "durationMs": 6000,
        "language": "ko"
      },
      {
        "lineIndex": 20,
        "text": "야무쳐야 이다.이 들어오는데",
        "startMs": 45440,
        "durationMs": 4040,
        "language": "ko"
      },
      {
        "lineIndex": 21,
        "text": "나는이 너무 얇은게 나 싫더라고.",
        "startMs": 51120,
        "durationMs": 3959,
        "language": "ko"
      },
      {
        "lineIndex": 22,
        "text": "좀 도톰해야지.",
        "startMs": 53399,
        "durationMs": 3881,
        "language": "ko"
      },
      {
        "lineIndex": 23,
        "text": "난변 거 좋아한다.이",
        "startMs": 55079,
        "durationMs": 3881,
        "language": "ko"
      },
      {
        "lineIndex": 24,
        "text": "또 불에 들어가서 너 또 떨어져야지.",
        "startMs": 57280,
        "durationMs": 3759,
        "language": "ko"
      },
      {
        "lineIndex": 25,
        "text": "자꾸 손을 대갖고 이러면 안 된다.",
        "startMs": 58960,
        "durationMs": 4279,
        "language": "ko"
      },
      {
        "lineIndex": 26,
        "text": "사람 손이 뜨거운 열이 얼마나",
        "startMs": 61039,
        "durationMs": 5400,
        "language": "ko"
      },
      {
        "lineIndex": 27,
        "text": "겁난다고. 자 그래. 그리고 어쨌든간",
        "startMs": 63239,
        "durationMs": 5321,
        "language": "ko"
      },
      {
        "lineIndex": 28,
        "text": "우리 국산 돼지를 사야 돼.",
        "startMs": 66439,
        "durationMs": 4201,
        "language": "ko"
      },
      {
        "lineIndex": 29,
        "text": "우리 국산 돼지는 되게 맛있거든.",
        "startMs": 68560,
        "durationMs": 4960,
        "language": "ko"
      },
      {
        "lineIndex": 30,
        "text": "수입은 아무리 뭐 잘 가공되더라도",
        "startMs": 70640,
        "durationMs": 4400,
        "language": "ko"
      },
      {
        "lineIndex": 31,
        "text": "냄새 난다.",
        "startMs": 73520,
        "durationMs": 4279,
        "language": "ko"
      },
      {
        "lineIndex": 32,
        "text": "여기다 이제 냄새 좀 잡아 주려면은",
        "startMs": 75040,
        "durationMs": 5280,
        "language": "ko"
      },
      {
        "lineIndex": 33,
        "text": "먼저 소주. 엄마는 소주가 항상",
        "startMs": 77799,
        "durationMs": 5401,
        "language": "ko"
      },
      {
        "lineIndex": 34,
        "text": "들어가거든. 두 숟가락.",
        "startMs": 80320,
        "durationMs": 4119,
        "language": "ko"
      },
      {
        "lineIndex": 35,
        "text": "그리고",
        "startMs": 83200,
        "durationMs": 3640,
        "language": "ko"
      },
      {
        "lineIndex": 36,
        "text": "엄마는이 고추층 그 설탕물을 좀",
        "startMs": 84439,
        "durationMs": 4481,
        "language": "ko"
      },
      {
        "lineIndex": 37,
        "text": "엮기거든. 다만 내 주는데",
        "startMs": 86840,
        "durationMs": 4840,
        "language": "ko"
      },
      {
        "lineIndex": 38,
        "text": "그 고추층 없는 사람은이 설탕 있지?",
        "startMs": 88920,
        "durationMs": 3920,
        "language": "ko"
      },
      {
        "lineIndex": 39,
        "text": "설탕",
        "startMs": 91680,
        "durationMs": 2799,
        "language": "ko"
      },
      {
        "lineIndex": 40,
        "text": "설탕을 한 숟가락",
        "startMs": 92840,
        "durationMs": 3279,
        "language": "ko"
      },
      {
        "lineIndex": 41,
        "text": "이걸 미리 딱 이리",
        "startMs": 94479,
        "durationMs": 3481,
        "language": "ko"
      },
      {
        "lineIndex": 42,
        "text": "밑관을 해 줘야 돼. 돼지고기에다",
        "startMs": 96119,
        "durationMs": 3360,
        "language": "ko"
      },
      {
        "lineIndex": 43,
        "text": "양념하기 전에",
        "startMs": 97960,
        "durationMs": 3760,
        "language": "ko"
      },
      {
        "lineIndex": 44,
        "text": "엄마는 고추청이 있으니까이",
        "startMs": 99479,
        "durationMs": 3881,
        "language": "ko"
      },
      {
        "lineIndex": 45,
        "text": "남제 고추청 다 끊임 먹고 나면이",
        "startMs": 101720,
        "durationMs": 4800,
        "language": "ko"
      },
      {
        "lineIndex": 46,
        "text": "물이 많이 남거든 그거 딱 저 먹고",
        "startMs": 103360,
        "durationMs": 7000,
        "language": "ko"
      },
      {
        "lineIndex": 47,
        "text": "딱 이런 병에 어 놨다가 이런데 써.",
        "startMs": 106520,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 48,
        "text": "음",
        "startMs": 110360,
        "durationMs": 2039,
        "language": "ko"
      },
      {
        "lineIndex": 49,
        "text": "이게 매콤하면서",
        "startMs": 111520,
        "durationMs": 2520,
        "language": "ko"
      },
      {
        "lineIndex": 50,
        "text": "매콤하면서 시큼하고",
        "startMs": 112399,
        "durationMs": 4400,
        "language": "ko"
      },
      {
        "lineIndex": 51,
        "text": "달콤하고 어 이거 이거를 이제 밑간을",
        "startMs": 114040,
        "durationMs": 4039,
        "language": "ko"
      },
      {
        "lineIndex": 52,
        "text": "해 줄 거라 엄마는",
        "startMs": 116799,
        "durationMs": 3121,
        "language": "ko"
      },
      {
        "lineIndex": 53,
        "text": "한 숟가락 하면 작으니까 한 숟가락",
        "startMs": 118079,
        "durationMs": 2921,
        "language": "ko"
      },
      {
        "lineIndex": 54,
        "text": "반만",
        "startMs": 119920,
        "durationMs": 2119,
        "language": "ko"
      },
      {
        "lineIndex": 55,
        "text": "응",
        "startMs": 121000,
        "durationMs": 1759,
        "language": "ko"
      },
      {
        "lineIndex": 56,
        "text": "이래 됐지",
        "startMs": 122039,
        "durationMs": 2561,
        "language": "ko"
      },
      {
        "lineIndex": 57,
        "text": "근데 엄마이",
        "startMs": 122759,
        "durationMs": 3680,
        "language": "ko"
      },
      {
        "lineIndex": 58,
        "text": "유자청 넣어도 되겠다 그지",
        "startMs": 124600,
        "durationMs": 3600,
        "language": "ko"
      },
      {
        "lineIndex": 59,
        "text": "근데 유자청은 유전에 안서",
        "startMs": 126439,
        "durationMs": 5201,
        "language": "ko"
      },
      {
        "lineIndex": 60,
        "text": "아니다 유자청 넣고 엄마",
        "startMs": 128200,
        "durationMs": 6920,
        "language": "ko"
      },
      {
        "lineIndex": 61,
        "text": "가만을 이거 한 숟가락 생강",
        "startMs": 131640,
        "durationMs": 3840,
        "language": "ko"
      },
      {
        "lineIndex": 62,
        "text": "생강",
        "startMs": 135120,
        "durationMs": 2160,
        "language": "ko"
      },
      {
        "lineIndex": 63,
        "text": "생강도 이제 누린내를 잡아주고",
        "startMs": 135480,
        "durationMs": 4000,
        "language": "ko"
      },
      {
        "lineIndex": 64,
        "text": "돼지고개는 필이 생강하고 하고",
        "startMs": 137280,
        "durationMs": 4679,
        "language": "ko"
      },
      {
        "lineIndex": 65,
        "text": "매실청하고 들어가야 되거든. 매실청은",
        "startMs": 139480,
        "durationMs": 3880,
        "language": "ko"
      },
      {
        "lineIndex": 66,
        "text": "나중에 이어 줄 거고 이걸 이래",
        "startMs": 141959,
        "durationMs": 7481,
        "language": "ko"
      },
      {
        "lineIndex": 67,
        "text": "가지고 일단 주물어 개미관을 먼저",
        "startMs": 143360,
        "durationMs": 6080,
        "language": "ko"
      },
      {
        "lineIndex": 68,
        "text": "이래 딱딱 나고 놔놓고 강이 되고",
        "startMs": 149519,
        "durationMs": 6481,
        "language": "ko"
      },
      {
        "lineIndex": 69,
        "text": "도녀에 들어 대파는 큰 거 한",
        "startMs": 153720,
        "durationMs": 4280,
        "language": "ko"
      },
      {
        "lineIndex": 70,
        "text": "뿌리다. 엄마는 이거 해파 이걸",
        "startMs": 156000,
        "durationMs": 3360,
        "language": "ko"
      },
      {
        "lineIndex": 71,
        "text": "샀거든.",
        "startMs": 158000,
        "durationMs": 2879,
        "language": "ko"
      },
      {
        "lineIndex": 72,
        "text": "대파는 하려면 어서 설기를 해야",
        "startMs": 159360,
        "durationMs": 3120,
        "language": "ko"
      },
      {
        "lineIndex": 73,
        "text": "된대.",
        "startMs": 160879,
        "durationMs": 3360,
        "language": "ko"
      },
      {
        "lineIndex": 74,
        "text": "양파는",
        "startMs": 162480,
        "durationMs": 3119,
        "language": "ko"
      },
      {
        "lineIndex": 75,
        "text": "예.",
        "startMs": 164239,
        "durationMs": 3801,
        "language": "ko"
      },
      {
        "lineIndex": 76,
        "text": "사분게 양파가 워낙 크다. 작은 거는",
        "startMs": 165599,
        "durationMs": 6761,
        "language": "ko"
      },
      {
        "lineIndex": 77,
        "text": "반개하고 딴 거는 조금만",
        "startMs": 168040,
        "durationMs": 4320,
        "language": "ko"
      },
      {
        "lineIndex": 78,
        "text": "초청한게",
        "startMs": 175640,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 79,
        "text": "안 매운 고추 청 있지? 부치게는 꼭",
        "startMs": 180840,
        "durationMs": 6840,
        "language": "ko"
      },
      {
        "lineIndex": 80,
        "text": "이게 홍초 청초가 들어가야 맛있다.",
        "startMs": 183400,
        "durationMs": 5800,
        "language": "ko"
      },
      {
        "lineIndex": 81,
        "text": "들어가고 땡초 두 개 엮기거든.",
        "startMs": 187680,
        "durationMs": 5160,
        "language": "ko"
      },
      {
        "lineIndex": 82,
        "text": "엄마는 칼칼하게",
        "startMs": 189200,
        "durationMs": 3640,
        "language": "ko"
      },
      {
        "lineIndex": 83,
        "text": "또 땡초 그 애들 주고 매운 사람은",
        "startMs": 193440,
        "durationMs": 3960,
        "language": "ko"
      },
      {
        "lineIndex": 84,
        "text": "안 넣어도 된대.",
        "startMs": 195760,
        "durationMs": 3839,
        "language": "ko"
      },
      {
        "lineIndex": 85,
        "text": "응.이 땡초가 들어가 줘야 돼지고기",
        "startMs": 197400,
        "durationMs": 4720,
        "language": "ko"
      },
      {
        "lineIndex": 86,
        "text": "합이다. 그리고 이제는 버섯개 열",
        "startMs": 199599,
        "durationMs": 5521,
        "language": "ko"
      },
      {
        "lineIndex": 87,
        "text": "건데 없는 사람 안도 된대. 이거",
        "startMs": 202120,
        "durationMs": 6360,
        "language": "ko"
      },
      {
        "lineIndex": 88,
        "text": "이제 양념 가는 진간장 세 개만",
        "startMs": 205120,
        "durationMs": 4720,
        "language": "ko"
      },
      {
        "lineIndex": 89,
        "text": "엮기거든.",
        "startMs": 208480,
        "durationMs": 4200,
        "language": "ko"
      },
      {
        "lineIndex": 90,
        "text": "고추장에 한 숟가락 들어가 줘야 돼.",
        "startMs": 209840,
        "durationMs": 5399,
        "language": "ko"
      },
      {
        "lineIndex": 91,
        "text": "고춧가락. 이거는 또 난재에 뭐 색깔",
        "startMs": 212680,
        "durationMs": 4400,
        "language": "ko"
      },
      {
        "lineIndex": 92,
        "text": "안 나면 더 퍼여 주면 되거든. 한",
        "startMs": 215239,
        "durationMs": 4360,
        "language": "ko"
      },
      {
        "lineIndex": 93,
        "text": "숟가락 넣고 매실청.",
        "startMs": 217080,
        "durationMs": 5519,
        "language": "ko"
      },
      {
        "lineIndex": 94,
        "text": "새큼 매실청 이것도 후추 여호 아까",
        "startMs": 219599,
        "durationMs": 5801,
        "language": "ko"
      },
      {
        "lineIndex": 95,
        "text": "저다 한 다 됐잖아.",
        "startMs": 222599,
        "durationMs": 6200,
        "language": "ko"
      },
      {
        "lineIndex": 96,
        "text": "후추 좋죠.",
        "startMs": 225400,
        "durationMs": 3399,
        "language": "ko"
      },
      {
        "lineIndex": 97,
        "text": "야채가 있는데 모지랄 거 같은데.",
        "startMs": 228840,
        "durationMs": 3959,
        "language": "ko"
      },
      {
        "lineIndex": 98,
        "text": "모지하면 고춧가락 한 숟가리 더",
        "startMs": 231120,
        "durationMs": 2640,
        "language": "ko"
      },
      {
        "lineIndex": 99,
        "text": "퍼여오면 되지 뭐.",
        "startMs": 232799,
        "durationMs": 2160,
        "language": "ko"
      },
      {
        "lineIndex": 100,
        "text": "아",
        "startMs": 233760,
        "durationMs": 3119,
        "language": "ko"
      },
      {
        "lineIndex": 101,
        "text": "그리고 여기 자꾸 하는 거보다 작을",
        "startMs": 234959,
        "durationMs": 4761,
        "language": "ko"
      },
      {
        "lineIndex": 102,
        "text": "때 여기다 해 줘야 응. 응. 응.",
        "startMs": 236879,
        "durationMs": 4560,
        "language": "ko"
      },
      {
        "lineIndex": 103,
        "text": "해 줘야 되지.",
        "startMs": 239720,
        "durationMs": 3519,
        "language": "ko"
      },
      {
        "lineIndex": 104,
        "text": "이제 펜 달아 놓고",
        "startMs": 241439,
        "durationMs": 3800,
        "language": "ko"
      },
      {
        "lineIndex": 105,
        "text": "수용이를 한 숟갈 이리 부어 줘.",
        "startMs": 243239,
        "durationMs": 3601,
        "language": "ko"
      },
      {
        "lineIndex": 106,
        "text": "한 숟갈. 그 어떻게 한 숟가리",
        "startMs": 245239,
        "durationMs": 2881,
        "language": "ko"
      },
      {
        "lineIndex": 107,
        "text": "그 이제 한 숟간이 아니라이 둘러",
        "startMs": 246840,
        "durationMs": 4720,
        "language": "ko"
      },
      {
        "lineIndex": 108,
        "text": "줘야 돼. 음 충분히",
        "startMs": 248120,
        "durationMs": 7520,
        "language": "ko"
      },
      {
        "lineIndex": 109,
        "text": "그래 아까 돼주고기 해 놓 거 있지이",
        "startMs": 251560,
        "durationMs": 4080,
        "language": "ko"
      },
      {
        "lineIndex": 110,
        "text": "한 살살는 거 이거를 응",
        "startMs": 255680,
        "durationMs": 5799,
        "language": "ko"
      },
      {
        "lineIndex": 111,
        "text": "주물르거 하면은 양념 야채 때문에",
        "startMs": 259079,
        "durationMs": 4281,
        "language": "ko"
      },
      {
        "lineIndex": 112,
        "text": "고기가 실실 있거든 물도 나오고",
        "startMs": 261479,
        "durationMs": 4881,
        "language": "ko"
      },
      {
        "lineIndex": 113,
        "text": "아",
        "startMs": 263360,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 114,
        "text": "이제 이거 고기를 먼저 강불에 딱",
        "startMs": 270120,
        "durationMs": 5160,
        "language": "ko"
      },
      {
        "lineIndex": 115,
        "text": "볶아 주면은 지으면서 기름이 나와 그",
        "startMs": 272680,
        "durationMs": 4400,
        "language": "ko"
      },
      {
        "lineIndex": 116,
        "text": "그 기름에 익 줘야 고기가 잠자더",
        "startMs": 275280,
        "durationMs": 4120,
        "language": "ko"
      },
      {
        "lineIndex": 117,
        "text": "날아가고 맛신다. 맛이 있다.",
        "startMs": 277080,
        "durationMs": 4080,
        "language": "ko"
      },
      {
        "lineIndex": 118,
        "text": "그것도 주물러가 있나?",
        "startMs": 279400,
        "durationMs": 4639,
        "language": "ko"
      },
      {
        "lineIndex": 119,
        "text": "그 야채 어 양념하고 야채 막 그",
        "startMs": 281160,
        "durationMs": 4960,
        "language": "ko"
      },
      {
        "lineIndex": 120,
        "text": "같이이 볶아 주면은",
        "startMs": 284039,
        "durationMs": 3921,
        "language": "ko"
      },
      {
        "lineIndex": 121,
        "text": "훨씬 열전도가 떨어지거든.",
        "startMs": 286120,
        "durationMs": 4280,
        "language": "ko"
      },
      {
        "lineIndex": 122,
        "text": "그지? 그 양념이 차가우니까.",
        "startMs": 287960,
        "durationMs": 3720,
        "language": "ko"
      },
      {
        "lineIndex": 123,
        "text": "그래 그래 그래 그래. 그리고",
        "startMs": 290400,
        "durationMs": 2720,
        "language": "ko"
      },
      {
        "lineIndex": 124,
        "text": "고기에서도 물이 또 질질 나오는",
        "startMs": 291680,
        "durationMs": 2480,
        "language": "ko"
      },
      {
        "lineIndex": 125,
        "text": "거라.이",
        "startMs": 293120,
        "durationMs": 3880,
        "language": "ko"
      },
      {
        "lineIndex": 126,
        "text": "먼저이 야쿠리판에 고기만 바짝 볶아",
        "startMs": 294160,
        "durationMs": 3720,
        "language": "ko"
      },
      {
        "lineIndex": 127,
        "text": "줘야 돼.",
        "startMs": 297000,
        "durationMs": 1800,
        "language": "ko"
      },
      {
        "lineIndex": 128,
        "text": "네. 탈",
        "startMs": 297880,
        "durationMs": 3440,
        "language": "ko"
      },
      {
        "lineIndex": 129,
        "text": "그치. 아 탁으로 말고 하여튼 고기가",
        "startMs": 298800,
        "durationMs": 4480,
        "language": "ko"
      },
      {
        "lineIndex": 130,
        "text": "그리고 충분히 고기 리카 주고 난는데",
        "startMs": 301320,
        "durationMs": 4240,
        "language": "ko"
      },
      {
        "lineIndex": 131,
        "text": "야채하고 양념 들어가면은이지가지",
        "startMs": 303280,
        "durationMs": 5520,
        "language": "ko"
      },
      {
        "lineIndex": 132,
        "text": "맛을 딱 지에 품고 있잖아.",
        "startMs": 305560,
        "durationMs": 4960,
        "language": "ko"
      },
      {
        "lineIndex": 133,
        "text": "그 이제 대용랑 하는 거 아니나?",
        "startMs": 308800,
        "durationMs": 3760,
        "language": "ko"
      },
      {
        "lineIndex": 134,
        "text": "대용랑. 어, 많이 하는 거는 이제",
        "startMs": 310520,
        "durationMs": 3920,
        "language": "ko"
      },
      {
        "lineIndex": 135,
        "text": "이렇게 우리 뭐 가정식으로 해먹는",
        "startMs": 312560,
        "durationMs": 4160,
        "language": "ko"
      },
      {
        "lineIndex": 136,
        "text": "것이 하면 안 되거든. 그러니까 이제",
        "startMs": 314440,
        "durationMs": 4400,
        "language": "ko"
      },
      {
        "lineIndex": 137,
        "text": "양념하고 밑간을 해갖고 딱 주물라 딱",
        "startMs": 316720,
        "durationMs": 4319,
        "language": "ko"
      },
      {
        "lineIndex": 138,
        "text": "따동 눌려 놓잖아. 그래. 이제 볶을",
        "startMs": 318840,
        "durationMs": 4479,
        "language": "ko"
      },
      {
        "lineIndex": 139,
        "text": "때는 조금씩 넣어 가지고 야,채 딱",
        "startMs": 321039,
        "durationMs": 6321,
        "language": "ko"
      },
      {
        "lineIndex": 140,
        "text": "넣고 이래 갖고 볶은다.이가",
        "startMs": 323319,
        "durationMs": 4041,
        "language": "ko"
      },
      {
        "lineIndex": 141,
        "text": "돼 있지?",
        "startMs": 332000,
        "durationMs": 3680,
        "language": "ko"
      },
      {
        "lineIndex": 142,
        "text": "을 때",
        "startMs": 333520,
        "durationMs": 5160,
        "language": "ko"
      },
      {
        "lineIndex": 143,
        "text": "들어다.",
        "startMs": 335680,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 144,
        "text": "싹하고",
        "startMs": 348240,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 145,
        "text": "남기고 남기고이",
        "startMs": 351919,
        "durationMs": 3481,
        "language": "ko"
      },
      {
        "lineIndex": 146,
        "text": "주는 거",
        "startMs": 356319,
        "durationMs": 3241,
        "language": "ko"
      },
      {
        "lineIndex": 147,
        "text": "색깔이 안 때는",
        "startMs": 363840,
        "durationMs": 4680,
        "language": "ko"
      },
      {
        "lineIndex": 148,
        "text": "고춧가루 더여주고 신고올 때는",
        "startMs": 366160,
        "durationMs": 4039,
        "language": "ko"
      },
      {
        "lineIndex": 149,
        "text": "소금이나",
        "startMs": 368520,
        "durationMs": 3200,
        "language": "ko"
      },
      {
        "lineIndex": 150,
        "text": "배관장",
        "startMs": 370199,
        "durationMs": 5241,
        "language": "ko"
      },
      {
        "lineIndex": 151,
        "text": "반지리 하려면은 나와 물려려면 되고",
        "startMs": 371720,
        "durationMs": 5190,
        "language": "ko"
      },
      {
        "lineIndex": 152,
        "text": "똑같네.",
        "startMs": 375440,
        "durationMs": 5289,
        "language": "ko"
      },
      {
        "lineIndex": 153,
        "text": "[박수]",
        "startMs": 376910,
        "durationMs": 3819,
        "language": "ko"
      },
      {
        "lineIndex": 154,
        "text": "하자.",
        "startMs": 385479,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 155,
        "text": "고춧까",
        "startMs": 388599,
        "durationMs": 5241,
        "language": "ko"
      },
      {
        "lineIndex": 156,
        "text": "지보자.",
        "startMs": 390840,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 157,
        "text": "나 이거 방아입도 한 개 하려다.이",
        "startMs": 399680,
        "durationMs": 3799,
        "language": "ko"
      },
      {
        "lineIndex": 158,
        "text": "방아입이거든.",
        "startMs": 402240,
        "durationMs": 4510,
        "language": "ko"
      },
      {
        "lineIndex": 159,
        "text": "되게 맛있대.",
        "startMs": 403479,
        "durationMs": 6451,
        "language": "ko"
      },
      {
        "lineIndex": 160,
        "text": "[박수]",
        "startMs": 406750,
        "durationMs": 3180,
        "language": "ko"
      },
      {
        "lineIndex": 161,
        "text": "내가 입에 줄게.",
        "startMs": 411160,
        "durationMs": 4759,
        "language": "ko"
      },
      {
        "lineIndex": 162,
        "text": "뜨거워서 어쩔래? 식바닥 되려. 자,",
        "startMs": 414160,
        "durationMs": 5159,
        "language": "ko"
      },
      {
        "lineIndex": 163,
        "text": "먹어 봐라. 아,",
        "startMs": 415919,
        "durationMs": 3400,
        "language": "ko"
      },
      {
        "lineIndex": 164,
        "text": "아이고 그렇게 놀래나?",
        "startMs": 419720,
        "durationMs": 3759,
        "language": "ko"
      },
      {
        "lineIndex": 165,
        "text": "진짜 맛있네.",
        "startMs": 422160,
        "durationMs": 2960,
        "language": "ko"
      },
      {
        "lineIndex": 166,
        "text": "방입부터 올게.",
        "startMs": 423479,
        "durationMs": 2881,
        "language": "ko"
      },
      {
        "lineIndex": 167,
        "text": "음.",
        "startMs": 425120,
        "durationMs": 3120,
        "language": "ko"
      },
      {
        "lineIndex": 168,
        "text": "진짜 허들 거 허들 스린게 아니고",
        "startMs": 426360,
        "durationMs": 4480,
        "language": "ko"
      },
      {
        "lineIndex": 169,
        "text": "진짜 맛있다.",
        "startMs": 428240,
        "durationMs": 7359,
        "language": "ko"
      },
      {
        "lineIndex": 170,
        "text": "뜨거우니까 식은 거 입에 여어 줄게.",
        "startMs": 430840,
        "durationMs": 6440,
        "language": "ko"
      },
      {
        "lineIndex": 171,
        "text": "아 해봐.",
        "startMs": 435599,
        "durationMs": 3481,
        "language": "ko"
      },
      {
        "lineIndex": 172,
        "text": "너무 맛있다.",
        "startMs": 437280,
        "durationMs": 2720,
        "language": "ko"
      },
      {
        "lineIndex": 173,
        "text": "왕이 향기.",
        "startMs": 439080,
        "durationMs": 2559,
        "language": "ko"
      },
      {
        "lineIndex": 174,
        "text": "음수",
        "startMs": 440000,
        "durationMs": 4199,
        "language": "ko"
      },
      {
        "lineIndex": 175,
        "text": "고지.",
        "startMs": 441639,
        "durationMs": 5840,
        "language": "ko"
      },
      {
        "lineIndex": 176,
        "text": "이거 어떻나?",
        "startMs": 444199,
        "durationMs": 3280,
        "language": "ko"
      },
      {
        "lineIndex": 177,
        "text": "음",
        "startMs": 448919,
        "durationMs": 2560,
        "language": "ko"
      },
      {
        "lineIndex": 178,
        "text": "초가서 먹으면 입천장돼 있다니까.",
        "startMs": 449599,
        "durationMs": 2961,
        "language": "ko"
      },
      {
        "lineIndex": 179,
        "text": "맛있지.",
        "startMs": 451479,
        "durationMs": 2481,
        "language": "ko"
      },
      {
        "lineIndex": 180,
        "text": "그 이게 이게 더 역할을 해",
        "startMs": 452560,
        "durationMs": 3840,
        "language": "ko"
      },
      {
        "lineIndex": 181,
        "text": "준다니까. 옥상에다",
        "startMs": 453960,
        "durationMs": 4079,
        "language": "ko"
      },
      {
        "lineIndex": 182,
        "text": "맛있네. 진짜 맛있다.",
        "startMs": 456400,
        "durationMs": 3880,
        "language": "ko"
      },
      {
        "lineIndex": 183,
        "text": "여기 원래 깻잎 올리면 맛있거든.",
        "startMs": 458039,
        "durationMs": 5041,
        "language": "ko"
      },
      {
        "lineIndex": 184,
        "text": "깻잎. 그이 방입이고 고기 항신는",
        "startMs": 460280,
        "durationMs": 4359,
        "language": "ko"
      },
      {
        "lineIndex": 185,
        "text": "서울 사람들 이걸 안 먹더라고.",
        "startMs": 463080,
        "durationMs": 4040,
        "language": "ko"
      },
      {
        "lineIndex": 186,
        "text": "먹지.",
        "startMs": 464639,
        "durationMs": 2481,
        "language": "ko"
      }
    ],
