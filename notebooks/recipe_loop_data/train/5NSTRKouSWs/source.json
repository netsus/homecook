    "segments": [
      {
        "lineIndex": 0,
        "text": "좋잖. 인간 쪽으로다가 어려운 건",
        "startMs": 160,
        "durationMs": 4720,
        "language": "ko"
      },
      {
        "lineIndex": 1,
        "text": "없어. 딱 맞으면 버터향이 확",
        "startMs": 3320,
        "durationMs": 4640,
        "language": "ko"
      },
      {
        "lineIndex": 2,
        "text": "올라와요. 한번 해 봐. 그만아.",
        "startMs": 4880,
        "durationMs": 6160,
        "language": "ko"
      },
      {
        "lineIndex": 3,
        "text": "네. 빵준을 사랑해 주시는 우리 허거",
        "startMs": 7960,
        "durationMs": 5719,
        "language": "ko"
      },
      {
        "lineIndex": 4,
        "text": "여러분 안녕하십니까? 또 어",
        "startMs": 11040,
        "durationMs": 4920,
        "language": "ko"
      },
      {
        "lineIndex": 5,
        "text": "여러분들을 뵙는 시간이 왔습니다.",
        "startMs": 13679,
        "durationMs": 5041,
        "language": "ko"
      },
      {
        "lineIndex": 6,
        "text": "그래서 오늘 또 준비했어. 뭐 마들렌",
        "startMs": 15960,
        "durationMs": 4559,
        "language": "ko"
      },
      {
        "lineIndex": 7,
        "text": "뭐야? 그거 마들렌 많잖아. 요것도",
        "startMs": 18720,
        "durationMs": 3799,
        "language": "ko"
      },
      {
        "lineIndex": 8,
        "text": "또 준서만의 스타일이 있어. 준서만의",
        "startMs": 20519,
        "durationMs": 3961,
        "language": "ko"
      },
      {
        "lineIndex": 9,
        "text": "스타일이. 예. 그래서 사실 준서가",
        "startMs": 22519,
        "durationMs": 5041,
        "language": "ko"
      },
      {
        "lineIndex": 10,
        "text": "하는 스타일이 마들레이 한 세 개지의",
        "startMs": 24480,
        "durationMs": 5039,
        "language": "ko"
      },
      {
        "lineIndex": 11,
        "text": "버전이 있어요. 세 가지에. 쌀로",
        "startMs": 27560,
        "durationMs": 4360,
        "language": "ko"
      },
      {
        "lineIndex": 12,
        "text": "하는 것도 있고 마지펜 같은 거를",
        "startMs": 29519,
        "durationMs": 4401,
        "language": "ko"
      },
      {
        "lineIndex": 13,
        "text": "이용해 갖고 촉촉하게 하는 것도 있고",
        "startMs": 31920,
        "durationMs": 4040,
        "language": "ko"
      },
      {
        "lineIndex": 14,
        "text": "근데 이제 오늘은 아주 노말한",
        "startMs": 33920,
        "durationMs": 4520,
        "language": "ko"
      },
      {
        "lineIndex": 15,
        "text": "기본적인 마들렌 아이 마들렌이네 요런",
        "startMs": 35960,
        "durationMs": 4480,
        "language": "ko"
      },
      {
        "lineIndex": 16,
        "text": "거 어 뽀송뽀송하네 원래 사실",
        "startMs": 38440,
        "durationMs": 4000,
        "language": "ko"
      },
      {
        "lineIndex": 17,
        "text": "여러분들 마들렌은 피난새나 이런",
        "startMs": 40440,
        "durationMs": 3799,
        "language": "ko"
      },
      {
        "lineIndex": 18,
        "text": "거보다는 좀 뽀송뽀송한게 있어요.",
        "startMs": 42440,
        "durationMs": 3200,
        "language": "ko"
      },
      {
        "lineIndex": 19,
        "text": "약간 스펀지 같은 요게 이제",
        "startMs": 44239,
        "durationMs": 3960,
        "language": "ko"
      },
      {
        "lineIndex": 20,
        "text": "마들렌이거든 근데 요게 파운드 같은",
        "startMs": 45640,
        "durationMs": 5800,
        "language": "ko"
      },
      {
        "lineIndex": 21,
        "text": "것과 원래 정통 마들렌의 중간 정도를",
        "startMs": 48199,
        "durationMs": 5641,
        "language": "ko"
      },
      {
        "lineIndex": 22,
        "text": "요즘 손님들은 좀 많이 알고 계신 거",
        "startMs": 51440,
        "durationMs": 4599,
        "language": "ko"
      },
      {
        "lineIndex": 23,
        "text": "같아. 근데 오늘 준서는 그냥 FM",
        "startMs": 53840,
        "durationMs": 4399,
        "language": "ko"
      },
      {
        "lineIndex": 24,
        "text": "그대로 이것이 마들레이요. 뭐 요런",
        "startMs": 56039,
        "durationMs": 6761,
        "language": "ko"
      },
      {
        "lineIndex": 25,
        "text": "스타일로 한번가 보도록 하겠습니다.",
        "startMs": 58239,
        "durationMs": 4561,
        "language": "ko"
      },
      {
        "lineIndex": 26,
        "text": "뭐라고? 남양주 오기가 너무 월다고.",
        "startMs": 64680,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 27,
        "text": "아휴도 준서가 또 준비했잖아. 준서가",
        "startMs": 67159,
        "durationMs": 5241,
        "language": "ko"
      },
      {
        "lineIndex": 28,
        "text": "준비했슈오. 준서가 만든요",
        "startMs": 69680,
        "durationMs": 5479,
        "language": "ko"
      },
      {
        "lineIndex": 29,
        "text": "명장 찹쌀떡. 아 이게 또 네임밸류가",
        "startMs": 72400,
        "durationMs": 5480,
        "language": "ko"
      },
      {
        "lineIndex": 30,
        "text": "있어. 준서가 또이 찹쌀떡을 기가",
        "startMs": 75159,
        "durationMs": 5041,
        "language": "ko"
      },
      {
        "lineIndex": 31,
        "text": "막히게 만들었거든.이 국산 찹쌀.",
        "startMs": 77880,
        "durationMs": 5160,
        "language": "ko"
      },
      {
        "lineIndex": 32,
        "text": "응. 국산 찹쌀에다가 팥도 안 달아.",
        "startMs": 80200,
        "durationMs": 4879,
        "language": "ko"
      },
      {
        "lineIndex": 33,
        "text": "브릭스를 한 48 브룩스 정도",
        "startMs": 83040,
        "durationMs": 4920,
        "language": "ko"
      },
      {
        "lineIndex": 34,
        "text": "준서만의 비법이 있어. 팥에다가 밤",
        "startMs": 85079,
        "durationMs": 5441,
        "language": "ko"
      },
      {
        "lineIndex": 35,
        "text": "호두 아우 간식으로는 기가 맞게.",
        "startMs": 87960,
        "durationMs": 7400,
        "language": "ko"
      },
      {
        "lineIndex": 36,
        "text": "특히 등상 갈 때 아 예술이야. 어음",
        "startMs": 90520,
        "durationMs": 7599,
        "language": "ko"
      },
      {
        "lineIndex": 37,
        "text": "라면 너무 멀어 그러면 댓글창 보시고",
        "startMs": 95360,
        "durationMs": 5759,
        "language": "ko"
      },
      {
        "lineIndex": 38,
        "text": "주문",
        "startMs": 98119,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 39,
        "text": "재료면 요렇게 단초해. 어려운 건",
        "startMs": 101880,
        "durationMs": 4400,
        "language": "ko"
      },
      {
        "lineIndex": 40,
        "text": "없어. 단 하나. 어 마들렌의 버터를",
        "startMs": 103799,
        "durationMs": 4521,
        "language": "ko"
      },
      {
        "lineIndex": 41,
        "text": "태워. 요런 거. 버터 약간 태울",
        "startMs": 106280,
        "durationMs": 3680,
        "language": "ko"
      },
      {
        "lineIndex": 42,
        "text": "거예요. 버터. 레몬이나 이런 걸",
        "startMs": 108320,
        "durationMs": 3880,
        "language": "ko"
      },
      {
        "lineIndex": 43,
        "text": "넣는 거는 요즘에 들어서 많이 이제",
        "startMs": 109960,
        "durationMs": 4759,
        "language": "ko"
      },
      {
        "lineIndex": 44,
        "text": "저기 바뀐 거고 사실 마들레는 원래",
        "startMs": 112200,
        "durationMs": 5599,
        "language": "ko"
      },
      {
        "lineIndex": 45,
        "text": "이제 밀가루 맛과 버터 요걸로 만드는",
        "startMs": 114719,
        "durationMs": 4921,
        "language": "ko"
      },
      {
        "lineIndex": 46,
        "text": "거예요. 예. 그래서 오늘은 그렇게",
        "startMs": 117799,
        "durationMs": 3680,
        "language": "ko"
      },
      {
        "lineIndex": 47,
        "text": "한번 가보도록 하겠습니다. 자,",
        "startMs": 119640,
        "durationMs": 4799,
        "language": "ko"
      },
      {
        "lineIndex": 48,
        "text": "일단은 먼저 재료를 섞고 그러고 나서",
        "startMs": 121479,
        "durationMs": 6760,
        "language": "ko"
      },
      {
        "lineIndex": 49,
        "text": "버터를 태울게요. 설탕, 꿀, 베이킹",
        "startMs": 124439,
        "durationMs": 6440,
        "language": "ko"
      },
      {
        "lineIndex": 50,
        "text": "파우더, 바닐라. 바닐라 없어. 안",
        "startMs": 128239,
        "durationMs": 4121,
        "language": "ko"
      },
      {
        "lineIndex": 51,
        "text": "넣어도 돼. 요구르트. 요구르트",
        "startMs": 130879,
        "durationMs": 3041,
        "language": "ko"
      },
      {
        "lineIndex": 52,
        "text": "없어? 안 돼. 있어야 돼. 그리고",
        "startMs": 132360,
        "durationMs": 4200,
        "language": "ko"
      },
      {
        "lineIndex": 53,
        "text": "결란. 결란은 실에 있던 거. 휘퍼주",
        "startMs": 133920,
        "durationMs": 4480,
        "language": "ko"
      },
      {
        "lineIndex": 54,
        "text": "섞어 주세요. 마들랭 같은 거 만들",
        "startMs": 136560,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 55,
        "text": "때 뭐가 포인트예요? 이렇게",
        "startMs": 138400,
        "durationMs": 2960,
        "language": "ko"
      },
      {
        "lineIndex": 56,
        "text": "얘기하잖아요. 사실 포인트라는 거",
        "startMs": 139560,
        "durationMs": 4520,
        "language": "ko"
      },
      {
        "lineIndex": 57,
        "text": "별로 없어. 마들랭 같은 거는 굳는",
        "startMs": 141360,
        "durationMs": 4640,
        "language": "ko"
      },
      {
        "lineIndex": 58,
        "text": "거가 좋아야 돼. 사실은 5분의",
        "startMs": 144080,
        "durationMs": 3720,
        "language": "ko"
      },
      {
        "lineIndex": 59,
        "text": "성능이거든요. 5분의 성능. 진짜",
        "startMs": 146000,
        "durationMs": 6160,
        "language": "ko"
      },
      {
        "lineIndex": 60,
        "text": "굳이 야 진짜로 노아오 있어. 하나",
        "startMs": 147800,
        "durationMs": 6560,
        "language": "ko"
      },
      {
        "lineIndex": 61,
        "text": "뭐 설탕이 녹아야 돼. 설탕이 안",
        "startMs": 152160,
        "durationMs": 3880,
        "language": "ko"
      },
      {
        "lineIndex": 62,
        "text": "녹으면 안 돼. 거품을 올리지 않는",
        "startMs": 154360,
        "durationMs": 3720,
        "language": "ko"
      },
      {
        "lineIndex": 63,
        "text": "반죽도 설탕이 녹는 거예요. 5분",
        "startMs": 156040,
        "durationMs": 3600,
        "language": "ko"
      },
      {
        "lineIndex": 64,
        "text": "안에 설탕이 녹았어. 그럼 머리",
        "startMs": 158080,
        "durationMs": 3879,
        "language": "ko"
      },
      {
        "lineIndex": 65,
        "text": "아파요. 진짜 내가 원했던 게로 안",
        "startMs": 159640,
        "durationMs": 4080,
        "language": "ko"
      },
      {
        "lineIndex": 66,
        "text": "나와. 그리고 설탕이 입자가 있었어.",
        "startMs": 161959,
        "durationMs": 3601,
        "language": "ko"
      },
      {
        "lineIndex": 67,
        "text": "그러면 일단 시가 안 좋아져. 설탕만",
        "startMs": 163720,
        "durationMs": 3720,
        "language": "ko"
      },
      {
        "lineIndex": 68,
        "text": "녹으면 돼. 설탕만. 여러분 밀가루",
        "startMs": 165560,
        "durationMs": 3880,
        "language": "ko"
      },
      {
        "lineIndex": 69,
        "text": "사실도이 마들랭 같은 거는 지금",
        "startMs": 167440,
        "durationMs": 5079,
        "language": "ko"
      },
      {
        "lineIndex": 70,
        "text": "준서가 드리는 레시피로 하면 숙성도",
        "startMs": 169440,
        "durationMs": 5200,
        "language": "ko"
      },
      {
        "lineIndex": 71,
        "text": "필요 없어. 숙성하면 좀 좋기는 해.",
        "startMs": 172519,
        "durationMs": 4841,
        "language": "ko"
      },
      {
        "lineIndex": 72,
        "text": "나쁘진 않아요. 왜냐면 숙성을 했어.",
        "startMs": 174640,
        "durationMs": 5200,
        "language": "ko"
      },
      {
        "lineIndex": 73,
        "text": "그럼 조금 더 오래 촉촉함을 유지할",
        "startMs": 177360,
        "durationMs": 4159,
        "language": "ko"
      },
      {
        "lineIndex": 74,
        "text": "수 있어요. 숙성을 하는 가장 큰",
        "startMs": 179840,
        "durationMs": 3759,
        "language": "ko"
      },
      {
        "lineIndex": 75,
        "text": "목적은. 근데 숙성 안 한 반죽을",
        "startMs": 181519,
        "durationMs": 4401,
        "language": "ko"
      },
      {
        "lineIndex": 76,
        "text": "오늘 해갖고 오늘 바로 걷어. 그러면",
        "startMs": 183599,
        "durationMs": 4761,
        "language": "ko"
      },
      {
        "lineIndex": 77,
        "text": "약간 건조함이 있어. 만들레니. 그럼",
        "startMs": 185920,
        "durationMs": 4360,
        "language": "ko"
      },
      {
        "lineIndex": 78,
        "text": "오늘 어떻게 나 오늘 바로 구해줘.",
        "startMs": 188360,
        "durationMs": 3760,
        "language": "ko"
      },
      {
        "lineIndex": 79,
        "text": "시간이 없는데. 어제 깜빡 까먹고",
        "startMs": 190280,
        "durationMs": 3840,
        "language": "ko"
      },
      {
        "lineIndex": 80,
        "text": "반죽을 안 했어.",
        "startMs": 192120,
        "durationMs": 4759,
        "language": "ko"
      },
      {
        "lineIndex": 81,
        "text": "섞어 주세요. 그냥 확 섞어 주세요.",
        "startMs": 194120,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 82,
        "text": "이렇게 섞어 주시고 그다음에 이제",
        "startMs": 196879,
        "durationMs": 3961,
        "language": "ko"
      },
      {
        "lineIndex": 83,
        "text": "버터 태울 건데 버터 태울 때",
        "startMs": 199120,
        "durationMs": 5360,
        "language": "ko"
      },
      {
        "lineIndex": 84,
        "text": "조심하셔야 돼요.",
        "startMs": 200840,
        "durationMs": 3640,
        "language": "ko"
      },
      {
        "lineIndex": 85,
        "text": "얘는 꼭 한 번에 안 되더라고. 불",
        "startMs": 205280,
        "durationMs": 5120,
        "language": "ko"
      },
      {
        "lineIndex": 86,
        "text": "약하게 놓고 요걸 살짝 놓고 먼저",
        "startMs": 208080,
        "durationMs": 4320,
        "language": "ko"
      },
      {
        "lineIndex": 87,
        "text": "이렇게 좀 녹여야 돼요. 버터. 아,",
        "startMs": 210400,
        "durationMs": 3839,
        "language": "ko"
      },
      {
        "lineIndex": 88,
        "text": "나 버터 태우는 거 처음 봐. 먹어",
        "startMs": 212400,
        "durationMs": 4919,
        "language": "ko"
      },
      {
        "lineIndex": 89,
        "text": "보면 마들렌이 딱 식었어. 그리고 그",
        "startMs": 214239,
        "durationMs": 4961,
        "language": "ko"
      },
      {
        "lineIndex": 90,
        "text": "태운 버터를",
        "startMs": 217319,
        "durationMs": 3721,
        "language": "ko"
      },
      {
        "lineIndex": 91,
        "text": "쓴 마들렌을 딱 먹잖아. 그러면",
        "startMs": 219200,
        "durationMs": 4759,
        "language": "ko"
      },
      {
        "lineIndex": 92,
        "text": "끝맛에 버터가 이렇게 쫙 올라와요.",
        "startMs": 221040,
        "durationMs": 4680,
        "language": "ko"
      },
      {
        "lineIndex": 93,
        "text": "드셔 보시만 하라. 주소가 무슨",
        "startMs": 223959,
        "durationMs": 3321,
        "language": "ko"
      },
      {
        "lineIndex": 94,
        "text": "얘기를 하는지. 여기서 너무 센불로",
        "startMs": 225720,
        "durationMs": 3040,
        "language": "ko"
      },
      {
        "lineIndex": 95,
        "text": "해 가지고 여기가 버터가 있는게",
        "startMs": 227280,
        "durationMs": 4080,
        "language": "ko"
      },
      {
        "lineIndex": 96,
        "text": "탔어. 그럼 냄새나. 잡내놔요. 타면",
        "startMs": 228760,
        "durationMs": 4319,
        "language": "ko"
      },
      {
        "lineIndex": 97,
        "text": "안 돼. 절대로. 그리고 내모 넣을",
        "startMs": 231360,
        "durationMs": 3840,
        "language": "ko"
      },
      {
        "lineIndex": 98,
        "text": "거야. 그러면은 버터 안 태우셔도",
        "startMs": 233079,
        "durationMs": 5720,
        "language": "ko"
      },
      {
        "lineIndex": 99,
        "text": "돼요. 저는 버터를 향을 극대화시키기",
        "startMs": 235200,
        "durationMs": 6080,
        "language": "ko"
      },
      {
        "lineIndex": 100,
        "text": "위해서 살짝 태우는 거거든요. 얘를",
        "startMs": 238799,
        "durationMs": 4961,
        "language": "ko"
      },
      {
        "lineIndex": 101,
        "text": "뭐 피난세하듯이 막 그렇게 태울게",
        "startMs": 241280,
        "durationMs": 4920,
        "language": "ko"
      },
      {
        "lineIndex": 102,
        "text": "아니에요. 많이 안 태우고 향만내는",
        "startMs": 243760,
        "durationMs": 4280,
        "language": "ko"
      },
      {
        "lineIndex": 103,
        "text": "거. 향만. 소위 말하면 버터 향.",
        "startMs": 246200,
        "durationMs": 3679,
        "language": "ko"
      },
      {
        "lineIndex": 104,
        "text": "얼만큼 태웠냐면 요거 보여 드릴게요.",
        "startMs": 248040,
        "durationMs": 5440,
        "language": "ko"
      },
      {
        "lineIndex": 105,
        "text": "제가 여러분 식물성 버터는 안 타요.",
        "startMs": 249879,
        "durationMs": 6241,
        "language": "ko"
      },
      {
        "lineIndex": 106,
        "text": "마가리는 안 타져요. 그래서 요거를",
        "startMs": 253480,
        "durationMs": 4920,
        "language": "ko"
      },
      {
        "lineIndex": 107,
        "text": "부어.",
        "startMs": 256120,
        "durationMs": 4839,
        "language": "ko"
      },
      {
        "lineIndex": 108,
        "text": "그 섞어.",
        "startMs": 258400,
        "durationMs": 4840,
        "language": "ko"
      },
      {
        "lineIndex": 109,
        "text": "버터 몇 도요? 바로 보면 돼요. 안",
        "startMs": 260959,
        "durationMs": 4680,
        "language": "ko"
      },
      {
        "lineIndex": 110,
        "text": "시켜도 돼? 안 시켜도 돼. 했죠?",
        "startMs": 263240,
        "durationMs": 5519,
        "language": "ko"
      },
      {
        "lineIndex": 111,
        "text": "이렇게. 요거 이제 조금만 15분 그",
        "startMs": 265639,
        "durationMs": 4840,
        "language": "ko"
      },
      {
        "lineIndex": 112,
        "text": "정도만 둘게요. 버터가 너무",
        "startMs": 268759,
        "durationMs": 3641,
        "language": "ko"
      },
      {
        "lineIndex": 113,
        "text": "뜨거웠으니까 덮을 필요도 없어. 그",
        "startMs": 270479,
        "durationMs": 4041,
        "language": "ko"
      },
      {
        "lineIndex": 114,
        "text": "농문데 시키는게 아니라 약간 안정",
        "startMs": 272400,
        "durationMs": 4160,
        "language": "ko"
      },
      {
        "lineIndex": 115,
        "text": "주는 거야. 안정. 막 휘적고 막",
        "startMs": 274520,
        "durationMs": 4040,
        "language": "ko"
      },
      {
        "lineIndex": 116,
        "text": "했으니까 살짝 안정 주시면 돼.",
        "startMs": 276560,
        "durationMs": 5840,
        "language": "ko"
      },
      {
        "lineIndex": 117,
        "text": "그리고 그동안에 뭐러냐 버터 발라요.",
        "startMs": 278560,
        "durationMs": 7720,
        "language": "ko"
      },
      {
        "lineIndex": 118,
        "text": "타월에다가 버터 해서 발라 주세요.이",
        "startMs": 282400,
        "durationMs": 5400,
        "language": "ko"
      },
      {
        "lineIndex": 119,
        "text": "툴이 이렇게 이제 많으면은 제가 이제",
        "startMs": 286280,
        "durationMs": 3880,
        "language": "ko"
      },
      {
        "lineIndex": 120,
        "text": "다른 방법을 해 줄 건데 오늘 양이",
        "startMs": 287800,
        "durationMs": 4560,
        "language": "ko"
      },
      {
        "lineIndex": 121,
        "text": "몇 개 안 되니까 그냥 타월로.",
        "startMs": 290160,
        "durationMs": 4479,
        "language": "ko"
      },
      {
        "lineIndex": 122,
        "text": "그리고 오늘 준서가 쓰는요 틀은 조금",
        "startMs": 292360,
        "durationMs": 4960,
        "language": "ko"
      },
      {
        "lineIndex": 123,
        "text": "깊은 거예요.이 마들렌 틀 얕은게",
        "startMs": 294639,
        "durationMs": 4681,
        "language": "ko"
      },
      {
        "lineIndex": 124,
        "text": "있고 깊은게 있더라고. 휘한새처럼.",
        "startMs": 297320,
        "durationMs": 4599,
        "language": "ko"
      },
      {
        "lineIndex": 125,
        "text": "그중에서 조금 깊은 거.",
        "startMs": 299320,
        "durationMs": 5640,
        "language": "ko"
      },
      {
        "lineIndex": 126,
        "text": "준비 끝난 규 한 10분 정도 휴지이",
        "startMs": 301919,
        "durationMs": 5761,
        "language": "ko"
      },
      {
        "lineIndex": 127,
        "text": "줬어요. 한번 살짝 섞어서 딱 맡으면",
        "startMs": 304960,
        "durationMs": 4840,
        "language": "ko"
      },
      {
        "lineIndex": 128,
        "text": "버터향이 확 올라와요. 이거는 버터",
        "startMs": 307680,
        "durationMs": 4400,
        "language": "ko"
      },
      {
        "lineIndex": 129,
        "text": "마들렌인 거예요. 그 버터 마들렌을",
        "startMs": 309800,
        "durationMs": 4280,
        "language": "ko"
      },
      {
        "lineIndex": 130,
        "text": "여러분들은 일반적인 마들렌이다 생각을",
        "startMs": 312080,
        "durationMs": 5920,
        "language": "ko"
      },
      {
        "lineIndex": 131,
        "text": "하시는 거죠. 그수는 30g 하나당.",
        "startMs": 314080,
        "durationMs": 7040,
        "language": "ko"
      },
      {
        "lineIndex": 132,
        "text": "원래 맞을래는 이제 밀가루하고",
        "startMs": 318000,
        "durationMs": 5759,
        "language": "ko"
      },
      {
        "lineIndex": 133,
        "text": "설탕하고 결환하고 꿀하고 버터 렇게",
        "startMs": 321120,
        "durationMs": 4720,
        "language": "ko"
      },
      {
        "lineIndex": 134,
        "text": "갖고 하는 거거든요. 향신료를",
        "startMs": 323759,
        "durationMs": 4560,
        "language": "ko"
      },
      {
        "lineIndex": 135,
        "text": "쓴다거나 뭐 레몬 같은 거를 쓴다거나",
        "startMs": 325840,
        "durationMs": 5079,
        "language": "ko"
      },
      {
        "lineIndex": 136,
        "text": "이렇게 안 했을 때는 결린내가 날",
        "startMs": 328319,
        "durationMs": 5121,
        "language": "ko"
      },
      {
        "lineIndex": 137,
        "text": "수밖에 없어요. 그래서 바닐라를 넣고",
        "startMs": 330919,
        "durationMs": 4761,
        "language": "ko"
      },
      {
        "lineIndex": 138,
        "text": "바닐라 맛을 내기 위해서 바닐라를",
        "startMs": 333440,
        "durationMs": 4319,
        "language": "ko"
      },
      {
        "lineIndex": 139,
        "text": "바닐라를 넣는게 아니에요, 여러분.",
        "startMs": 335680,
        "durationMs": 3440,
        "language": "ko"
      },
      {
        "lineIndex": 140,
        "text": "잡내를 잡기 위해서 쓰는 거예요.",
        "startMs": 337759,
        "durationMs": 3720,
        "language": "ko"
      },
      {
        "lineIndex": 141,
        "text": "향신료 같은 경우는 버터를 태운 거는",
        "startMs": 339120,
        "durationMs": 4560,
        "language": "ko"
      },
      {
        "lineIndex": 142,
        "text": "버터 향을 풍부하게 내기 위함이에요.",
        "startMs": 341479,
        "durationMs": 4321,
        "language": "ko"
      },
      {
        "lineIndex": 143,
        "text": "그러니까 이렇게 내가 어떤 행위를함에",
        "startMs": 343680,
        "durationMs": 4040,
        "language": "ko"
      },
      {
        "lineIndex": 144,
        "text": "있어서 제품을 만들 때 분명하게",
        "startMs": 345800,
        "durationMs": 3360,
        "language": "ko"
      },
      {
        "lineIndex": 145,
        "text": "목적이 있어야 돼요. 레스피에",
        "startMs": 347720,
        "durationMs": 3319,
        "language": "ko"
      },
      {
        "lineIndex": 146,
        "text": "있어서가 아니라 예. 내가 뭘 할",
        "startMs": 349160,
        "durationMs": 3920,
        "language": "ko"
      },
      {
        "lineIndex": 147,
        "text": "거야. 그럼 목적을 반드시 두세요.",
        "startMs": 351039,
        "durationMs": 4641,
        "language": "ko"
      },
      {
        "lineIndex": 148,
        "text": "네. 요렇게 짰죠? 일단",
        "startMs": 353080,
        "durationMs": 5050,
        "language": "ko"
      },
      {
        "lineIndex": 149,
        "text": "170도예요.",
        "startMs": 355680,
        "durationMs": 6409,
        "language": "ko"
      },
      {
        "lineIndex": 150,
        "text": "[음악]",
        "startMs": 358130,
        "durationMs": 3959,
        "language": "ko"
      },
      {
        "lineIndex": 151,
        "text": "요거 지금 170도에 10분 꿨어요.",
        "startMs": 365120,
        "durationMs": 6400,
        "language": "ko"
      },
      {
        "lineIndex": 152,
        "text": "10분.요 한 여섯 개는 술을 바를",
        "startMs": 368280,
        "durationMs": 5759,
        "language": "ko"
      },
      {
        "lineIndex": 153,
        "text": "거예요. 뜨거운 상태에서 마들렌이",
        "startMs": 371520,
        "durationMs": 4519,
        "language": "ko"
      },
      {
        "lineIndex": 154,
        "text": "요렇게 나오면 참 이쁘게 잘 나온",
        "startMs": 374039,
        "durationMs": 5361,
        "language": "ko"
      },
      {
        "lineIndex": 155,
        "text": "거죠. 좋잖아요. 인간 쪽으로다가",
        "startMs": 376039,
        "durationMs": 5720,
        "language": "ko"
      },
      {
        "lineIndex": 156,
        "text": "마들 그냥 대충 그냥 하면 이렇게",
        "startMs": 379400,
        "durationMs": 4720,
        "language": "ko"
      },
      {
        "lineIndex": 157,
        "text": "나와요. 그죠? 대충 렇게 그냥",
        "startMs": 381759,
        "durationMs": 4000,
        "language": "ko"
      },
      {
        "lineIndex": 158,
        "text": "거시기 하면 나와요. 어려운 거",
        "startMs": 384120,
        "durationMs": 3280,
        "language": "ko"
      },
      {
        "lineIndex": 159,
        "text": "없어. 그 뭐 여기다가 이제 혼당을",
        "startMs": 385759,
        "durationMs": 4121,
        "language": "ko"
      },
      {
        "lineIndex": 160,
        "text": "바르신다거나 뭐 막 요렇게 하시면",
        "startMs": 387400,
        "durationMs": 4199,
        "language": "ko"
      },
      {
        "lineIndex": 161,
        "text": "되고. 원 이제 영 약간 시켜서",
        "startMs": 389880,
        "durationMs": 4439,
        "language": "ko"
      },
      {
        "lineIndex": 162,
        "text": "먹어야 되는데 한번 잘라 볼게요.",
        "startMs": 391599,
        "durationMs": 5361,
        "language": "ko"
      },
      {
        "lineIndex": 163,
        "text": "이게 마들렌",
        "startMs": 394319,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 164,
        "text": "같은 거 요런 거는 사실 진짜 맛있게",
        "startMs": 396960,
        "durationMs": 5160,
        "language": "ko"
      },
      {
        "lineIndex": 165,
        "text": "드실 거면 살짝 미열이 남았을 때",
        "startMs": 399319,
        "durationMs": 4561,
        "language": "ko"
      },
      {
        "lineIndex": 166,
        "text": "포장하시면 좋아요. 사실은 마들랭",
        "startMs": 402120,
        "durationMs": 3720,
        "language": "ko"
      },
      {
        "lineIndex": 167,
        "text": "같은 경우에는 오늘 만들어서 오늘",
        "startMs": 403880,
        "durationMs": 3920,
        "language": "ko"
      },
      {
        "lineIndex": 168,
        "text": "파는 거보다 내일 파시는게 좋아요.",
        "startMs": 405840,
        "durationMs": 4880,
        "language": "ko"
      },
      {
        "lineIndex": 169,
        "text": "살짝 덜 식었을 때 포장 탁 해 갖고",
        "startMs": 407800,
        "durationMs": 4839,
        "language": "ko"
      },
      {
        "lineIndex": 170,
        "text": "숙성을 하루 딱 해서 내일 딱",
        "startMs": 410720,
        "durationMs": 4199,
        "language": "ko"
      },
      {
        "lineIndex": 171,
        "text": "먹으면이 봉지를 딱 따았을 때 내가",
        "startMs": 412639,
        "durationMs": 5280,
        "language": "ko"
      },
      {
        "lineIndex": 172,
        "text": "버터의 향을 준 마들레야. 그러면",
        "startMs": 414919,
        "durationMs": 5120,
        "language": "ko"
      },
      {
        "lineIndex": 173,
        "text": "버터 향이 쫙 올라와야 돼. 그 버터",
        "startMs": 417919,
        "durationMs": 4081,
        "language": "ko"
      },
      {
        "lineIndex": 174,
        "text": "캐라멜 레이징 탁 해 갖고 한 그",
        "startMs": 420039,
        "durationMs": 4641,
        "language": "ko"
      },
      {
        "lineIndex": 175,
        "text": "버터 향이 탁 들어온다고. 요게",
        "startMs": 422000,
        "durationMs": 4520,
        "language": "ko"
      },
      {
        "lineIndex": 176,
        "text": "준서가 원래 원했던 맛이냐? 이게",
        "startMs": 424680,
        "durationMs": 3639,
        "language": "ko"
      },
      {
        "lineIndex": 177,
        "text": "내일 지나면 훨씬 맛있어요. 오늘",
        "startMs": 426520,
        "durationMs": 4550,
        "language": "ko"
      },
      {
        "lineIndex": 178,
        "text": "일단 한번 먹어 볼게요.",
        "startMs": 428319,
        "durationMs": 5361,
        "language": "ko"
      },
      {
        "lineIndex": 179,
        "text": "[음악]",
        "startMs": 431070,
        "durationMs": 5409,
        "language": "ko"
      },
      {
        "lineIndex": 180,
        "text": "지금은 냉정하게 말씀드리면 럼을 바른",
        "startMs": 433680,
        "durationMs": 4639,
        "language": "ko"
      },
      {
        "lineIndex": 181,
        "text": "걸 먹었거든요. 여기 럼을 바른이",
        "startMs": 436479,
        "durationMs": 3961,
        "language": "ko"
      },
      {
        "lineIndex": 182,
        "text": "표면에 맛이 딱 혀를 담아 알싸해.",
        "startMs": 438319,
        "durationMs": 4600,
        "language": "ko"
      },
      {
        "lineIndex": 183,
        "text": "그 알콜에 맛이 있어 갖고. 근데",
        "startMs": 440440,
        "durationMs": 5240,
        "language": "ko"
      },
      {
        "lineIndex": 184,
        "text": "끝맛은 까맣게. 그리고 술을 바른",
        "startMs": 442919,
        "durationMs": 4481,
        "language": "ko"
      },
      {
        "lineIndex": 185,
        "text": "과자는 그날 드시는 거 아니에요.",
        "startMs": 445680,
        "durationMs": 5830,
        "language": "ko"
      },
      {
        "lineIndex": 186,
        "text": "최소한 3시간 4시간 지난다.",
        "startMs": 447400,
        "durationMs": 7000,
        "language": "ko"
      },
      {
        "lineIndex": 187,
        "text": "[음악]",
        "startMs": 451510,
        "durationMs": 5450,
        "language": "ko"
      },
      {
        "lineIndex": 188,
        "text": "버터 향도 여러분들 한번 해 봐.",
        "startMs": 454400,
        "durationMs": 5440,
        "language": "ko"
      },
      {
        "lineIndex": 189,
        "text": "그만 준서가 뭘 얘기하는 요거 한번",
        "startMs": 456960,
        "durationMs": 4880,
        "language": "ko"
      },
      {
        "lineIndex": 190,
        "text": "해 보시고 준서가 여기 왜 있겠어요?",
        "startMs": 459840,
        "durationMs": 3840,
        "language": "ko"
      },
      {
        "lineIndex": 191,
        "text": "여러분들의 사랑받으려고 있는 거",
        "startMs": 461840,
        "durationMs": 2799,
        "language": "ko"
      },
      {
        "lineIndex": 192,
        "text": "아니에요? 그죠? 예. 그럼",
        "startMs": 463680,
        "durationMs": 2959,
        "language": "ko"
      },
      {
        "lineIndex": 193,
        "text": "여러분들은 또 사랑을 모르죠? 추천",
        "startMs": 464639,
        "durationMs": 3921,
        "language": "ko"
      },
      {
        "lineIndex": 194,
        "text": "구독 좋아요, 알람 설정 귀엽게",
        "startMs": 466639,
        "durationMs": 5000,
        "language": "ko"
      },
      {
        "lineIndex": 195,
        "text": "딸랑딸랑 거 꽉 부탁드리면서 마들렌",
        "startMs": 468560,
        "durationMs": 4800,
        "language": "ko"
      },
      {
        "lineIndex": 196,
        "text": "올 여름이 가기 전에 한번 꼭 해",
        "startMs": 471639,
        "durationMs": 3921,
        "language": "ko"
      },
      {
        "lineIndex": 197,
        "text": "보시고 아우 준서가 느꼈던 그 맛",
        "startMs": 473360,
        "durationMs": 4399,
        "language": "ko"
      },
      {
        "lineIndex": 198,
        "text": "여러분들 함께 공유할 수 있는 그런",
        "startMs": 475560,
        "durationMs": 3960,
        "language": "ko"
      },
      {
        "lineIndex": 199,
        "text": "귀한 시간이 될 수 있었으면",
        "startMs": 477759,
        "durationMs": 3601,
        "language": "ko"
      },
      {
        "lineIndex": 200,
        "text": "좋겠습니다. 여러분 사랑합니다.",
        "startMs": 479520,
        "durationMs": 3450,
        "language": "ko"
      },
      {
        "lineIndex": 201,
        "text": "안녕히계십시오.",
        "startMs": 481360,
        "durationMs": 4739,
        "language": "ko"
      },
      {
        "lineIndex": 202,
