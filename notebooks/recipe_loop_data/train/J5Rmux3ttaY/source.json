    "segments": [
      {
        "lineIndex": 0,
        "text": "안녕하세요 좁은 에라 입니다 오늘은",
        "startMs": 4170,
        "durationMs": 6480,
        "language": "ko"
      },
      {
        "lineIndex": 1,
        "text": "고추 다대기 말고 다시 마다 되기를",
        "startMs": 7020,
        "durationMs": 6289,
        "language": "ko"
      },
      {
        "lineIndex": 2,
        "text": "알려 드릴 건데요",
        "startMs": 10650,
        "durationMs": 2659,
        "language": "ko"
      },
      {
        "lineIndex": 3,
        "text": "저희 안산 로마 님께서 보통 닭 고추",
        "startMs": 13339,
        "durationMs": 4981,
        "language": "ko"
      },
      {
        "lineIndex": 4,
        "text": "다대기 말 있는 수 많은 데다 심하다",
        "startMs": 16129,
        "durationMs": 3990,
        "language": "ko"
      },
      {
        "lineIndex": 5,
        "text": "되기도 했는데 이게 너무 맛있다면서",
        "startMs": 18320,
        "durationMs": 5400,
        "language": "ko"
      },
      {
        "lineIndex": 6,
        "text": "한번 해보라 면서 카톡에",
        "startMs": 20119,
        "durationMs": 4951,
        "language": "ko"
      },
      {
        "lineIndex": 7,
        "text": "장문의",
        "startMs": 23720,
        "durationMs": 4500,
        "language": "ko"
      },
      {
        "lineIndex": 8,
        "text": "엄 문자를 주셨어요",
        "startMs": 25070,
        "durationMs": 5520,
        "language": "ko"
      },
      {
        "lineIndex": 9,
        "text": "진짜로 제가 해 먹어 보니까 너무",
        "startMs": 28220,
        "durationMs": 4850,
        "language": "ko"
      },
      {
        "lineIndex": 10,
        "text": "맛있더라구요",
        "startMs": 30590,
        "durationMs": 4640,
        "language": "ko"
      },
      {
        "lineIndex": 11,
        "text": "다시면 또 건강이나 아주 좋으니까",
        "startMs": 33070,
        "durationMs": 6540,
        "language": "ko"
      },
      {
        "lineIndex": 12,
        "text": "한번 만들어 볼까요 먼저 다시마를",
        "startMs": 35230,
        "durationMs": 8070,
        "language": "ko"
      },
      {
        "lineIndex": 13,
        "text": "물에 등 거 가지고 한 30분정도",
        "startMs": 39610,
        "durationMs": 7460,
        "language": "ko"
      },
      {
        "lineIndex": 14,
        "text": "풀리 라고 하시더라구요",
        "startMs": 43300,
        "durationMs": 3770,
        "language": "ko"
      },
      {
        "lineIndex": 15,
        "text": "얼마전에 된장 맛있게 만드는 방법",
        "startMs": 47590,
        "durationMs": 4740,
        "language": "ko"
      },
      {
        "lineIndex": 16,
        "text": "올렸더니 엄청나게 많이들",
        "startMs": 50590,
        "durationMs": 2970,
        "language": "ko"
      },
      {
        "lineIndex": 17,
        "text": "좋아하시더라구요",
        "startMs": 52330,
        "durationMs": 4280,
        "language": "ko"
      },
      {
        "lineIndex": 18,
        "text": "지금 30분정도 불렸던 이 요렇게",
        "startMs": 53560,
        "durationMs": 7080,
        "language": "ko"
      },
      {
        "lineIndex": 19,
        "text": "통통해 됐어요 매그 미끈하게",
        "startMs": 56610,
        "durationMs": 7000,
        "language": "ko"
      },
      {
        "lineIndex": 20,
        "text": "소쿠리에 건져 가지고 물이 빠질 동안",
        "startMs": 60640,
        "durationMs": 6690,
        "language": "ko"
      },
      {
        "lineIndex": 21,
        "text": "두고요 다른 재료 한번 준비해 볼게요",
        "startMs": 63610,
        "durationMs": 6900,
        "language": "ko"
      },
      {
        "lineIndex": 22,
        "text": "일단 마늘이 좀 필요합니다",
        "startMs": 67330,
        "durationMs": 5399,
        "language": "ko"
      },
      {
        "lineIndex": 23,
        "text": "재료는",
        "startMs": 70510,
        "durationMs": 4800,
        "language": "ko"
      },
      {
        "lineIndex": 24,
        "text": "다시마가 일단 주인공이니까 다시마",
        "startMs": 72729,
        "durationMs": 6210,
        "language": "ko"
      },
      {
        "lineIndex": 25,
        "text": "같이 많아야 된다고 해요",
        "startMs": 75310,
        "durationMs": 6000,
        "language": "ko"
      },
      {
        "lineIndex": 26,
        "text": "하늘 있으며 썸 지어 주시고요 없으면",
        "startMs": 78939,
        "durationMs": 5040,
        "language": "ko"
      },
      {
        "lineIndex": 27,
        "text": "그냥 눈 시력 벌어놓은 만 하셔도 될",
        "startMs": 81310,
        "durationMs": 4229,
        "language": "ko"
      },
      {
        "lineIndex": 28,
        "text": "것 같아요",
        "startMs": 83979,
        "durationMs": 4771,
        "language": "ko"
      },
      {
        "lineIndex": 29,
        "text": "그리고 밀치 필요한데요 저희 그려 장",
        "startMs": 85539,
        "durationMs": 5311,
        "language": "ko"
      },
      {
        "lineIndex": 30,
        "text": "낼지 밖에 없어요",
        "startMs": 88750,
        "durationMs": 6690,
        "language": "ko"
      },
      {
        "lineIndex": 31,
        "text": "굵은 멸치 하셔도 됩니다 빠 가지고",
        "startMs": 90850,
        "durationMs": 7470,
        "language": "ko"
      },
      {
        "lineIndex": 32,
        "text": "음 일치가 쪼매 해가지고",
        "startMs": 95440,
        "durationMs": 6210,
        "language": "ko"
      },
      {
        "lineIndex": 33,
        "text": "2 이 잘 안쓰지만 이미 이 그다지",
        "startMs": 98320,
        "durationMs": 7760,
        "language": "ko"
      },
      {
        "lineIndex": 34,
        "text": "라고 하던데 뭐 n3 줘 아",
        "startMs": 101650,
        "durationMs": 4430,
        "language": "ko"
      },
      {
        "lineIndex": 35,
        "text": "네 곡이 유역의 가야되서 안되게 펴기",
        "startMs": 107390,
        "durationMs": 4070,
        "language": "ko"
      },
      {
        "lineIndex": 36,
        "text": "하십시오",
        "startMs": 110090,
        "durationMs": 5120,
        "language": "ko"
      },
      {
        "lineIndex": 37,
        "text": "커터기 에 커터 커터 일단 하고",
        "startMs": 111460,
        "durationMs": 5760,
        "language": "ko"
      },
      {
        "lineIndex": 38,
        "text": "여러분 들어 시간되시면 그냥 칼로",
