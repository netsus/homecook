        "durationMs": 5180,
        "language": "ko"
      },
      {
        "lineIndex": 68,
        "text": "옴",
        "startMs": 194630,
        "durationMs": 4460,
        "language": "ko"
      },
      {
        "lineIndex": 69,
        "text": "음 감소 소리의 진동을 느끼면서",
