      },
      {
        "lineIndex": 96,
        "text": "기름 치도 있는 거 아무거나 끌러",
        "startMs": 267010,
        "durationMs": 3570,
        "language": "ko"
      },
      {
        "lineIndex": 97,
        "text": "줍니다",
        "startMs": 269290,
        "durationMs": 3570,
        "language": "ko"
      },
      {
        "lineIndex": 98,
        "text": "저는 아보카도 키를 쓰니까 굉장히",
        "startMs": 270580,
        "durationMs": 4610,
        "language": "ko"
      },
      {
        "lineIndex": 99,
        "text": "맑고 법도 한 것도 없고 좋더라구요",
        "startMs": 272860,
        "durationMs": 7040,
        "language": "ko"
      },
      {
        "lineIndex": 100,
        "text": "그래서 먼저 좀 멸치 다져 놓은 것을",
        "startMs": 275190,
        "durationMs": 8460,
        "language": "ko"
      },
      {
        "lineIndex": 101,
        "text": "달달달 포 꽉 입니다",
        "startMs": 279900,
        "durationMs": 3750,
        "language": "ko"
      },
      {
        "lineIndex": 102,
        "text": "몸에도 멸치도 놓고",
        "startMs": 287819,
        "durationMs": 3561,
        "language": "ko"
      },
      {
        "lineIndex": 103,
        "text": "어느 정도 볶아지면",
        "startMs": 294030,
        "durationMs": 7020,
        "language": "ko"
      },
      {
        "lineIndex": 104,
        "text": "또 다져놓은 다시마를 넣어 줍니다",
        "startMs": 296880,
        "durationMs": 6540,
        "language": "ko"
      },
      {
        "lineIndex": 105,
        "text": "보기에 나온 다시마가 복코 지어서 만",
        "startMs": 301050,
        "durationMs": 4980,
        "language": "ko"
      },
      {
        "lineIndex": 106,
        "text": "없을 것 같은데 이런 느낌인데 좋으며",
        "startMs": 303420,
        "durationMs": 3870,
        "language": "ko"
      },
      {
        "lineIndex": 107,
        "text": "아니에요",
        "startMs": 306030,
        "durationMs": 4359,
        "language": "ko"
      },
      {
        "lineIndex": 108,
        "text": "아주 뜻밖의 마시니까",
        "startMs": 307290,
        "durationMs": 5590,
        "language": "ko"
      },
      {
        "lineIndex": 109,
        "text": "잘 단 디몰 데이",
        "startMs": 310389,
        "durationMs": 7101,
        "language": "ko"
      },
      {
        "lineIndex": 110,
        "text": "이거 뭐 투수로 나온 거 좀 넣구요",
        "startMs": 312880,
        "durationMs": 4610,
        "language": "ko"
      },
      {
        "lineIndex": 111,
        "text": "고추 하고",
        "startMs": 321589,
        "durationMs": 4890,
        "language": "ko"
      },
      {
        "lineIndex": 112,
        "text": "이런것은 다시마가 양이 훨씬 많으며",
        "startMs": 323960,
        "durationMs": 4709,
        "language": "ko"
      },
      {
        "lineIndex": 113,
        "text": "맛있다고 하니까 딱히 마약을 조금",
        "startMs": 326479,
        "durationMs": 4830,
        "language": "ko"
      },
      {
        "lineIndex": 114,
        "text": "많이 아세요 어느만큼 인지는",
        "startMs": 328669,
        "durationMs": 5670,
        "language": "ko"
      },
      {
        "lineIndex": 115,
        "text": "안 알려 주시고 그냥 데 료마 하는",
        "startMs": 331309,
        "durationMs": 6140,
        "language": "ko"
      },
      {
        "lineIndex": 116,
        "text": "방법 마 알려주시더라구요",
        "startMs": 334339,
        "durationMs": 3110,
        "language": "ko"
      },
      {
        "lineIndex": 117,
        "text": "않아서 이제 뭐얏 너 무 일까",
        "startMs": 338389,
        "durationMs": 5460,
        "language": "ko"
      },
      {
        "lineIndex": 118,
        "text": "다시마가 말하면 맛이 또 사워 그 말",
        "startMs": 341389,
        "durationMs": 5610,
        "language": "ko"
      },
      {
        "lineIndex": 119,
        "text": "말하더라고요 그 말 줌마",
        "startMs": 343849,
        "durationMs": 6000,
        "language": "ko"
      },
      {
        "lineIndex": 120,
        "text": "어쨌든 이런 맛있는 음식 굴 팁들",
        "startMs": 346999,
        "durationMs": 5040,
        "language": "ko"
      },
      {
        "lineIndex": 121,
        "text": "알려 주셔서 너무 감사합니다 사러 는",
        "startMs": 349849,
        "durationMs": 5690,
        "language": "ko"
      },
      {
        "lineIndex": 122,
        "text": "사돈 어르신 c 3",
        "startMs": 352039,
        "durationMs": 3500,
        "language": "ko"
      },
      {
        "lineIndex": 123,
        "text": "새날이 여아 들어요 니 어서 서울의",
        "startMs": 355710,
        "durationMs": 4890,
        "language": "ko"
      },
      {
        "lineIndex": 124,
        "text": "여행 갑상 하더라구요 아주 재미",
        "startMs": 358500,
        "durationMs": 3330,
        "language": "ko"
      },
      {
        "lineIndex": 125,
        "text": "때에요",
        "startMs": 360600,
        "durationMs": 2160,
        "language": "ko"
      },
      {
        "lineIndex": 126,
        "text": "예",
        "startMs": 361830,
        "durationMs": 4680,
        "language": "ko"
      },
      {
        "lineIndex": 127,
        "text": "응 게다가 막 간장을 부어 줍니다",
        "startMs": 362760,
        "durationMs": 4980,
        "language": "ko"
      },
      {
        "lineIndex": 128,
        "text": "아깐 장",
        "startMs": 366510,
        "durationMs": 3840,
        "language": "ko"
      },
      {
        "lineIndex": 129,
        "text": "얀 1.4 후보와 한번 드셔보시고",
        "startMs": 367740,
        "durationMs": 7070,
        "language": "ko"
      },
      {
        "lineIndex": 130,
        "text": "않을 맞추면 될 것 같아요",
        "startMs": 370350,
        "durationMs": 4460,
        "language": "ko"
      },
      {
        "lineIndex": 131,
        "text": "아 자식들이 어디가서 재밌고 즐겁게",
        "startMs": 374930,
        "durationMs": 5070,
        "language": "ko"
      },
      {
        "lineIndex": 132,
        "text": "놀고 있으니까 그렇게 거 못하고서 올",
        "startMs": 377509,
        "durationMs": 6421,
        "language": "ko"
      },
      {
        "lineIndex": 133,
        "text": "수가 없어요 예 맞죠 예 안장 꺾고",
        "startMs": 380000,
        "durationMs": 6300,
        "language": "ko"
      },
      {
        "lineIndex": 134,
        "text": "그리고 물을 조금 자박하게 부어",
        "startMs": 383930,
        "durationMs": 5820,
        "language": "ko"
      },
      {
        "lineIndex": 135,
        "text": "가지고 한소끔 꺼려 줍니다 다이바",
        "startMs": 386300,
        "durationMs": 4709,
        "language": "ko"
      },
      {
        "lineIndex": 136,
        "text": "1박을",
        "startMs": 389750,
        "durationMs": 4320,
        "language": "ko"
      },
      {
        "lineIndex": 137,
        "text": "재료들이 정부 좋은 성분들이 우러나",
        "startMs": 391009,
        "durationMs": 5311,
        "language": "ko"
      },
      {
        "lineIndex": 138,
        "text": "가지고 서로 서로 합당을 할 수",
        "startMs": 394070,
        "durationMs": 4170,
        "language": "ko"
      },
      {
        "lineIndex": 139,
        "text": "있도록 해줍니다",
        "startMs": 396320,
        "durationMs": 4319,
        "language": "ko"
      },
      {
        "lineIndex": 140,
        "text": "모든 좋은 성분들이 나빠져 넣어",
        "startMs": 398240,
        "durationMs": 6390,
        "language": "ko"
      },
      {
        "lineIndex": 141,
        "text": "나와가지고 같이 어우러져 써 맛이 없",
        "startMs": 400639,
        "durationMs": 5541,
        "language": "ko"
      },
      {
        "lineIndex": 142,
        "text": "될 수 있도록",
        "startMs": 404630,
        "durationMs": 4550,
        "language": "ko"
      },
      {
        "lineIndex": 143,
        "text": "해줍니다",
        "startMs": 406180,
        "durationMs": 3000,
        "language": "ko"
      },
      {
        "lineIndex": 144,
        "text": "그리고 마늘 찧어 놓은거",
        "startMs": 411560,
        "durationMs": 5960,
        "language": "ko"
      },
      {
        "lineIndex": 145,
        "text": "넣구요",
        "startMs": 415100,
        "durationMs": 2420,
        "language": "ko"
      },
      {
        "lineIndex": 146,
        "text": "고춧가루도 조금 넣구요",
        "startMs": 422330,
        "durationMs": 4530,
        "language": "ko"
      },
      {
        "lineIndex": 147,
        "text": "또",
        "startMs": 425780,
        "durationMs": 1879,
        "language": "ko"
      },
      {
        "lineIndex": 148,
        "text": "1회",
        "startMs": 426860,
        "durationMs": 4079,
        "language": "ko"
      },
      {
        "lineIndex": 149,
        "text": "올리고당이나 머물려 같은 매트 매너",
        "startMs": 427659,
        "durationMs": 6401,
        "language": "ko"
      },
      {
        "lineIndex": 150,
        "text": "적당량 넣어줍니다 저는요 살 올리고당",
        "startMs": 430939,
        "durationMs": 6151,
        "language": "ko"
      },
      {
        "lineIndex": 151,
        "text": "역의 집에 있어가지고 녹을 넣었어요",
        "startMs": 434060,
        "durationMs": 6370,
        "language": "ko"
      },
      {
        "lineIndex": 152,
        "text": "노래 가지고 한번 꺾어 면서",
        "startMs": 437090,
        "durationMs": 6540,
        "language": "ko"
      },
      {
        "lineIndex": 153,
        "text": "섞여 없습니다",
        "startMs": 440430,
        "durationMs": 3200,
        "language": "ko"
      },
      {
        "lineIndex": 154,
        "text": "아",
        "startMs": 455480,
        "durationMs": 2030,
        "language": "ko"
      },
      {
        "lineIndex": 155,
        "text": "잘했어 이제",
        "startMs": 457770,
        "durationMs": 5490,
        "language": "ko"
      },
      {
        "lineIndex": 156,
        "text": "불 꺼구요",
        "startMs": 460390,
        "durationMs": 2870,
        "language": "ko"
      },
      {
        "lineIndex": 157,
        "text": "밥에 나가지고",
        "startMs": 466830,
        "durationMs": 4130,
        "language": "ko"
      },
      {
        "lineIndex": 158,
        "text": "비벼먹으면 완전",
        "startMs": 468210,
        "durationMs": 2750,
        "language": "ko"
      },
      {
        "lineIndex": 159,
        "text": "개꼴 마시라고 요소 해야될 말로",
        "startMs": 470970,
        "durationMs": 3960,
        "language": "ko"
      },
      {
        "lineIndex": 160,
        "text": "그러더라구요 그게 뭔 말인지 잘",
        "startMs": 473040,
        "durationMs": 3120,
        "language": "ko"
      },
      {
        "lineIndex": 161,
        "text": "모르겠는데",
        "startMs": 474930,
        "durationMs": 3960,
        "language": "ko"
      },
      {
        "lineIndex": 162,
        "text": "아요 참 다대기 라고 하니까 일본말이",
        "startMs": 476160,
        "durationMs": 5610,
        "language": "ko"
      },
      {
        "lineIndex": 163,
        "text": "해보고 나서 안된다고 하시더라고요",
        "startMs": 478890,
        "durationMs": 5370,
        "language": "ko"
      },
      {
        "lineIndex": 164,
        "text": "조림 이라고 하라고 하던데",
        "startMs": 481770,
        "durationMs": 4710,
        "language": "ko"
      },
      {
        "lineIndex": 165,
        "text": "자 빨리 라고 해야되나 이렇게 그걸",
        "startMs": 484260,
        "durationMs": 6440,
        "language": "ko"
      },
      {
        "lineIndex": 166,
        "text": "뭐라고 해야 되면 다시 맛 조리",
        "startMs": 486480,
        "durationMs": 4220,
        "language": "ko"
      },
      {
        "lineIndex": 167,
        "text": "다음부터는 고쳐 쓰겠습니다 아연 님들",
        "startMs": 490800,
        "durationMs": 3810,
        "language": "ko"
      },
      {
        "lineIndex": 168,
        "text": "죄송합니다",
        "startMs": 492990,
        "durationMs": 3450,
        "language": "ko"
      },
      {
        "lineIndex": 169,
        "text": "다대기 라고 해야지 옛날 어르신들은",
        "startMs": 494610,
        "durationMs": 4700,
        "language": "ko"
      },
      {
        "lineIndex": 170,
        "text": "또 알아도 드시더라구요",
        "startMs": 496440,
        "durationMs": 2870,
        "language": "ko"
      },
      {
        "lineIndex": 171,
        "text": "입이 어서 먹어 보고 막 평가를 해",
        "startMs": 501950,
        "durationMs": 4880,
        "language": "ko"
      },
      {
        "lineIndex": 172,
        "text": "드릴께요",
        "startMs": 504139,
        "durationMs": 2691,
        "language": "ko"
      },
      {
        "lineIndex": 173,
        "text": "음",
        "startMs": 515240,
        "durationMs": 2900,
        "language": "ko"
      },
      {
        "lineIndex": 174,
        "text": "다시마가 저 여기 c 피워",
        "startMs": 518300,
        "durationMs": 5420,
        "language": "ko"
      },
      {
        "lineIndex": 175,
        "text": "멸치",
        "startMs": 522469,
        "durationMs": 4771,
        "language": "ko"
      },
      {
        "lineIndex": 176,
        "text": "고수한 마 타고 많은 엣 안내하고",
        "startMs": 523720,
        "durationMs": 6700,
        "language": "ko"
      },
      {
        "lineIndex": 177,
        "text": "어우 정말 맛있어요",
        "startMs": 527240,
        "durationMs": 5130,
        "language": "ko"
      },
      {
        "lineIndex": 178,
        "text": "어쩌다 대비마마 씹히는 맛이 없는",
        "startMs": 530420,
        "durationMs": 5220,
        "language": "ko"
      },
      {
        "lineIndex": 179,
        "text": "데려 다시마가 저 쪽 이쪽은 쪽에",
        "startMs": 532370,
        "durationMs": 5280,
        "language": "ko"
      },
      {
        "lineIndex": 180,
        "text": "씹히는게 너무 많이 했네요",
        "startMs": 535640,
        "durationMs": 4400,
        "language": "ko"
      },
      {
        "lineIndex": 181,
        "text": "음",
        "startMs": 537650,
        "durationMs": 2390,
        "language": "ko"
      },
      {
        "lineIndex": 182,
        "text": "222",
        "startMs": 541520,
        "durationMs": 4330,
        "language": "ko"
      },
      {
        "lineIndex": 183,
        "text": "으 음",
        "startMs": 543760,
        "durationMs": 6120,
        "language": "ko"
      },
      {
        "lineIndex": 184,
        "text": "짠짠짠 하게 하지 마라 2 음 프",
        "startMs": 545850,
        "durationMs": 7860,
        "language": "ko"
      },
      {
        "lineIndex": 185,
        "text": "9시 나인가 3 2 으",
        "startMs": 549880,
        "durationMs": 3830,
        "language": "ko"
      },
      {
        "lineIndex": 186,
        "text": "짬짬히 지우지 않아 유찰 봐요 안녕",
        "startMs": 554190,
        "durationMs": 8820,
        "language": "ko"
      },
      {
        "lineIndex": 187,
        "text": "4 4짜 음",
        "startMs": 558490,
        "durationMs": 8910,
        "language": "ko"
      },
      {
        "lineIndex": 188,
        "text": "음 뭘 와줄 막 나온다",
        "startMs": 563010,
        "durationMs": 7110,
        "language": "ko"
      },
      {
        "lineIndex": 189,
        "text": "너무 맛있었어",
        "startMs": 567400,
        "durationMs": 2720,
        "language": "ko"
      }
    ],
