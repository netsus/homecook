        "startMs": 139740,
        "durationMs": 6360,
        "language": "ko"
      },
      {
        "lineIndex": 49,
        "text": "그리고 고추 너 매운거 못드시는 분은",
        "startMs": 142620,
        "durationMs": 5430,
        "language": "ko"
      },
      {
