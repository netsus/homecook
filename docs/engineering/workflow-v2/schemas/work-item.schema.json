{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/engineering/workflow-v2/schemas/work-item.schema.json",
  "title": "Workflow V2 Work Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "project_profile",
    "change_type",
    "surface",
    "risk",
    "preset",
    "goal",
    "owners",
    "docs_refs",
    "workflow",
    "verification",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "project_profile": {
      "type": "string",
      "minLength": 1
    },
    "change_type": {
      "type": "string",
      "enum": ["product", "bugfix", "ui-polish", "infra-governance", "docs-only"]
    },
    "surface": {
      "type": "string",
      "enum": ["backend", "frontend", "fullstack", "workflow", "external-integration"]
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "preset": {
      "type": "string",
      "enum": [
        "vertical-slice-strict",
        "vertical-slice-light",
        "bugfix-patch",
        "ui-polish",
        "infra-governance",
        "docs-only"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "owners": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claude", "codex", "workers"],
      "properties": {
        "claude": {
          "type": "string",
          "minLength": 1
        },
        "codex": {
          "type": "string",
          "minLength": 1
        },
        "workers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "docs_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_of_truth", "governing_docs"],
      "properties": {
        "source_of_truth": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "governing_docs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plan_loop", "review_loop", "external_smokes"],
      "properties": {
        "plan_loop": {
          "type": "string",
          "enum": ["required", "recommended", "optional", "skipped"]
        },
        "review_loop": {
          "type": "string",
          "enum": ["required", "recommended", "optional", "skipped"]
        },
        "external_smokes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "execution_mode": {
          "type": "string",
          "enum": ["manual", "autonomous"]
        },
        "evaluator_profile": {
          "type": "string"
        },
        "merge_policy": {
          "type": "string",
          "enum": ["manual", "conditional-auto"]
        },
        "max_fix_rounds": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "backend": {
              "type": "integer",
              "minimum": 1
            },
            "frontend": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_checks", "verify_commands"],
      "properties": {
        "required_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verify_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evaluator_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifact_assertions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lifecycle", "approval_state", "verification_status"],
      "properties": {
        "lifecycle": {
          "type": "string",
          "enum": ["planned", "in_progress", "ready_for_review", "blocked", "merged", "archived"]
        },
        "approval_state": {
          "type": "string",
          "enum": [
            "not_started",
            "needs_revision",
            "claude_approved",
            "codex_approved",
            "dual_approved",
            "human_escalation"
          ]
        },
        "verification_status": {
          "type": "string",
          "enum": ["pending", "passed", "failed", "skipped"]
        },
        "evaluation_status": {
          "type": "string",
          "enum": ["not_started", "running", "fixable", "passed", "blocked", "stalled"]
        },
        "evaluation_round": {
          "type": "integer",
          "minimum": 0
        },
        "last_evaluator_result": {
          "type": ["string", "null"]
        },
        "auto_merge_eligible": {
          "type": "boolean"
        },
        "blocked_reason_code": {
          "type": ["string", "null"]
        }
      }
    },
    "closeout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "docs_projection",
        "verification_projection",
        "merge_gate_projection",
        "recovery_summary",
        "projection_state"
      ],
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["collecting", "projecting", "completed", "exception"]
        },
        "docs_projection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "roadmap_lifecycle",
            "design_status",
            "delivery_checklist",
            "design_authority",
            "acceptance",
            "automation_spec_metadata"
          ],
          "properties": {
            "roadmap_lifecycle": {
              "type": "string",
              "enum": ["planned", "in_progress", "ready_for_review", "blocked", "merged", "archived"]
            },
            "design_status": {
              "type": "string",
              "enum": ["temporary", "pending-review", "confirmed", "N/A"]
            },
            "delivery_checklist": {
              "type": "string",
              "enum": ["pending", "complete", "waived"]
            },
            "design_authority": {
              "type": "string",
              "enum": ["not_required", "pending", "passed", "failed", "waived"]
            },
            "acceptance": {
              "type": "string",
              "enum": ["pending", "complete", "waived"]
            },
            "automation_spec_metadata": {
              "type": "string",
              "enum": ["pending", "synced", "not_required"]
            }
          }
        },
        "verification_projection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_checks",
            "external_smokes",
            "authority_reports",
            "actual_verification_refs"
          ],
          "properties": {
            "required_checks": {
              "type": "string",
              "enum": ["pending", "passed", "failed", "skipped"]
            },
            "external_smokes": {
              "type": "string",
              "enum": ["pending", "passed", "failed", "skipped"]
            },
            "authority_reports": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "actual_verification_refs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "merge_gate_projection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["current_head_sha", "approval_state", "all_checks_green"],
          "properties": {
            "current_head_sha": {
              "type": "string",
              "minLength": 1
            },
            "approval_state": {
              "type": "string",
              "enum": [
                "not_started",
                "needs_revision",
                "claude_approved",
                "codex_approved",
                "dual_approved",
                "human_escalation"
              ]
            },
            "all_checks_green": {
              "type": "boolean"
            }
          }
        },
        "recovery_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "manual_patch_count",
            "manual_handoff",
            "stale_lock_count",
            "ci_resync_count",
            "artifact_missing",
            "last_recovery_at"
          ],
          "properties": {
            "manual_patch_count": {
              "type": "integer",
              "minimum": 0
            },
            "manual_handoff": {
              "type": "boolean"
            },
            "stale_lock_count": {
              "type": "integer",
              "minimum": 0
            },
            "ci_resync_count": {
              "type": "integer",
              "minimum": 0
            },
            "artifact_missing": {
              "type": "boolean"
            },
            "last_recovery_at": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "projection_state": {
          "type": "object",
          "additionalProperties": false,
          "required": ["docs_synced_at", "status_synced_at", "pr_body_synced_at"],
          "properties": {
            "docs_synced_at": {
              "type": "string",
              "minLength": 1
            },
            "status_synced_at": {
              "type": "string",
              "minLength": 1
            },
            "pr_body_synced_at": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
