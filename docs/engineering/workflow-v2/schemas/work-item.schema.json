{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/engineering/workflow-v2/schemas/work-item.schema.json",
  "title": "Workflow V2 Work Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "project_profile",
    "change_type",
    "surface",
    "risk",
    "preset",
    "goal",
    "owners",
    "docs_refs",
    "workflow",
    "verification",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "project_profile": {
      "type": "string",
      "minLength": 1
    },
    "change_type": {
      "type": "string",
      "enum": ["product", "bugfix", "ui-polish", "infra-governance", "docs-only"]
    },
    "surface": {
      "type": "string",
      "enum": ["backend", "frontend", "fullstack", "workflow", "external-integration"]
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "preset": {
      "type": "string",
      "enum": [
        "vertical-slice-strict",
        "vertical-slice-light",
        "bugfix-patch",
        "ui-polish",
        "infra-governance",
        "docs-only"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "owners": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claude", "codex", "workers"],
      "properties": {
        "claude": {
          "type": "string",
          "minLength": 1
        },
        "codex": {
          "type": "string",
          "minLength": 1
        },
        "workers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "docs_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_of_truth", "governing_docs"],
      "properties": {
        "source_of_truth": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "governing_docs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plan_loop", "review_loop", "external_smokes"],
      "properties": {
        "plan_loop": {
          "type": "string",
          "enum": ["required", "recommended", "optional", "skipped"]
        },
        "review_loop": {
          "type": "string",
          "enum": ["required", "recommended", "optional", "skipped"]
        },
        "external_smokes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_checks", "verify_commands"],
      "properties": {
        "required_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verify_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lifecycle", "approval_state", "verification_status"],
      "properties": {
        "lifecycle": {
          "type": "string",
          "enum": ["planned", "in_progress", "ready_for_review", "blocked", "merged", "archived"]
        },
        "approval_state": {
          "type": "string",
          "enum": [
            "not_started",
            "needs_revision",
            "claude_approved",
            "codex_approved",
            "dual_approved",
            "human_escalation"
          ]
        },
        "verification_status": {
          "type": "string",
          "enum": ["pending", "passed", "failed", "skipped"]
        }
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
