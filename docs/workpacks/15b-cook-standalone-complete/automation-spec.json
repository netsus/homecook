    "invariants": [
      "owner-authorization",
      "no-meals-status-mutation",
      "no-cooking-sessions-creation",
      "planner-standalone-separation",
      "leftover-dishes-insert",
      "pantry-items-delete-consumed",
      "pantry-empty-consumed-no-delete",
      "recipes-cook-count-increment",
      "atomic-transaction",
      "cook-mode-unauthenticated-access",
      "standalone-complete-authenticated-only",
      "recipe-not-found-404",
      "invalid-servings-422",
      "api-envelope-format"
    ],
    "verify_commands": [
      "pnpm verify:backend"
    ],
    "required_test_targets": [
      "tests/cook-standalone-complete.backend.test.ts"
    ]
  },
  "frontend": {
    "required_routes": [
      "/recipes/[recipe_id]/cook-mode"
    ],
    "required_states": [
      "loading",
      "error",
      "read-only",
      "unauthorized"
    ],
    "verify_commands": [
