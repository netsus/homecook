      "trace.zip",
      "screenshot"
    ],
    "design_authority": {
      "ui_risk": "low-risk",
      "anchor_screens": [
        "RECIPE_DETAIL"
      ],
      "required_screens": [
        "COOK_MODE"
      ],
      "generator_required": false,
      "generator_artifact": "ui/designs/COOK_MODE.md",
      "critic_required": false,
      "critic_artifact": "ui/designs/critiques/COOK_MODE-critique.md",
      "authority_required": false,
      "stage4_evidence_requirements": [],
      "authority_report_paths": []
    }
  },
  "external_smokes": [
    "pnpm dev:local-supabase"
  ],
  "blocked_conditions": [
    "official-doc-conflict",
    "referenced-table-missing",
    "leftover-dishes-table-missing",
    "pantry-items-table-missing",
    "recipes-table-missing",
