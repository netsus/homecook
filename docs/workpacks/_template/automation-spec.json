{
  "slice_id": "<slice-name>",
  "execution_mode": "autonomous",
  "risk_class": "medium",
  "merge_policy": "conditional-auto",
  "backend": {
    "required_endpoints": [
      "POST /api/v1/example"
    ],
    "invariants": [
      "documented-state-transition",
      "owner-authorization",
      "read-only-guard"
    ],
    "verify_commands": [
      "pnpm verify:backend"
    ],
    "required_test_targets": [
      "tests/<slice>.backend.test.ts"
    ]
  },
  "frontend": {
    "required_routes": [
      "/example"
    ],
    "required_states": [
      "loading",
      "empty",
      "error",
      "read-only",
      "unauthorized"
    ],
    "playwright_projects": [
      "desktop-chrome",
      "mobile-chrome",
      "mobile-ios-small"
    ],
    "artifact_assertions": [
      "playwright-report",
      "trace.zip",
      "screenshot"
    ]
  },
  "external_smokes": [],
  "blocked_conditions": [
    "official-doc-conflict",
    "secret-missing",
    "oauth-live-only"
  ],
  "max_fix_rounds": {
    "backend": 4,
    "frontend": 4
  }
}
