NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
YOUTUBE_API_KEY=your-youtube-data-api-key
DATA_GO_KR_API_KEY=your-public-data-portal-service-key
# Optional override. If omitted, external ingredient live fetch falls back to DATA_GO_KR_API_KEY for RDA data.go.kr APIs.
KOREANFOOD_RDA_API_KEY=your-koreanfood-rda-openapi-key
# YouTube description parser mode: v2 | legacy | shadow
HOMECOOK_YOUTUBE_DESCRIPTION_PARSER=v2
# Optional Gemini fallback for sparse YouTube recipe text/captions.
YOUTUBE_RECIPE_LLM_ENABLED=true
YOUTUBE_RECIPE_LLM_PROVIDER=gemini
# Legacy single-key fallback.
GEMINI_API_KEY=your-paid-gemini-api-key
# Optional ordered Gemini failover: free key first, paid key second.
GEMINI_API_KEY_FREE=your-free-gemini-api-key
GEMINI_API_KEY_PAID=your-paid-gemini-api-key
# Alternative ordered list.
# GEMINI_API_KEYS=your-free-gemini-api-key,your-paid-gemini-api-key
YOUTUBE_RECIPE_LLM_PRIMARY_MODEL=gemini-3.1-flash-lite
YOUTUBE_RECIPE_LLM_FALLBACK_MODEL=gemini-2.5-flash-lite
YOUTUBE_RECIPE_VISUAL_RECIPE_ENABLED=true
YOUTUBE_RECIPE_VISUAL_RECIPE_PROVIDER=gemini
YOUTUBE_RECIPE_VISUAL_RECIPE_MODEL=gemini-3.1-flash-lite
# Optional rollback only. Omit or set true to keep visual recipe extraction available.
YOUTUBE_RECIPE_VISUAL_RECIPE_CONTRACT_ALIGNED=true
YOUTUBE_RECIPE_VISUAL_QUANTITY_ENABLED=true
YOUTUBE_RECIPE_VISUAL_QUANTITY_PROVIDER=gemini
YOUTUBE_RECIPE_VISUAL_QUANTITY_MODEL=gemini-3.1-flash-lite
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public canonical origin used by metadata, robots.txt, and sitemap.xml.
# Set this to the final production domain before marketing launch.
NEXT_PUBLIC_SITE_URL=https://your-production-domain.example
NEXT_PUBLIC_SERVICE_CONTACT_EMAIL=replace-with-public-support-email
NEXT_PUBLIC_LEGAL_OPERATOR_NAME=replace-with-operator-name
NEXT_PUBLIC_LEGAL_EFFECTIVE_DATE=replace-with-effective-date
NEXT_PUBLIC_PRIVACY_OFFICER_NAME=replace-with-privacy-officer-name
NEXT_PUBLIC_PRIVACY_OFFICER_CONTACT=replace-with-privacy-officer-contact
NEXT_PUBLIC_LEGAL_THIRD_PARTY_SHARING=replace-with-third-party-sharing-status
NEXT_PUBLIC_LEGAL_PROCESSING_CONSIGNMENT=replace-with-processing-consignment-status
NEXT_PUBLIC_LEGAL_CHILD_ACCOUNT_POLICY=replace-with-child-account-policy
NEXT_PUBLIC_PRIVACY_COMPLAINT_DEPARTMENT=replace-with-privacy-complaint-department
NEXT_PUBLIC_PRIVACY_COMPLAINT_CONTACT=replace-with-privacy-complaint-contact
NEXT_PUBLIC_LEGAL_PROCESSING_CONSIGNMENT_WORK=replace-with-processing-consignment-work
NEXT_PUBLIC_LEGAL_THIRD_PARTY_SHARING_PURPOSE=replace-with-third-party-sharing-purpose
NEXT_PUBLIC_LEGAL_THIRD_PARTY_SHARING_ITEMS=replace-with-third-party-sharing-items
NEXT_PUBLIC_LEGAL_THIRD_PARTY_SHARING_RETENTION=replace-with-third-party-sharing-retention
NEXT_PUBLIC_LEGAL_OVERSEAS_TRANSFER_RECIPIENT=replace-with-overseas-transfer-recipient
NEXT_PUBLIC_LEGAL_OVERSEAS_TRANSFER_CONTACT=replace-with-overseas-transfer-contact
NEXT_PUBLIC_LEGAL_OVERSEAS_TRANSFER_COUNTRY=replace-with-overseas-transfer-country
NEXT_PUBLIC_LEGAL_OVERSEAS_TRANSFER_ITEMS=replace-with-overseas-transfer-items
NEXT_PUBLIC_LEGAL_OVERSEAS_TRANSFER_PURPOSE=replace-with-overseas-transfer-purpose
NEXT_PUBLIC_LEGAL_OVERSEAS_TRANSFER_METHOD=replace-with-overseas-transfer-method
NEXT_PUBLIC_LEGAL_OVERSEAS_TRANSFER_RETENTION=replace-with-overseas-transfer-retention
NEXT_PUBLIC_LEGAL_OVERSEAS_TRANSFER_LEGAL_BASIS=replace-with-overseas-transfer-legal-basis
NEXT_PUBLIC_ENABLED_AUTH_PROVIDERS=kakao,naver,google
# Naver is configured through Supabase Custom OAuth Providers.
NEXT_PUBLIC_NAVER_SUPABASE_PROVIDER=custom:naver
