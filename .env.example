NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
YOUTUBE_API_KEY=your-youtube-data-api-key
DATA_GO_KR_API_KEY=your-public-data-portal-service-key
# Optional override. If omitted, external ingredient live fetch falls back to DATA_GO_KR_API_KEY for RDA data.go.kr APIs.
KOREANFOOD_RDA_API_KEY=your-koreanfood-rda-openapi-key
# YouTube description parser mode: v2 | legacy | shadow
HOMECOOK_YOUTUBE_DESCRIPTION_PARSER=v2
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLED_AUTH_PROVIDERS=google
