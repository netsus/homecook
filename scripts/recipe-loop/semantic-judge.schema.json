{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["cases", "average_score"],
  "properties": {
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "ingredient_score", "step_score", "case_score", "reason"],
        "properties": {
          "title": { "type": "string" },
          "ingredient_score": { "type": "number", "minimum": 0, "maximum": 5 },
          "step_score": { "type": "number", "minimum": 0, "maximum": 5 },
          "case_score": { "type": "number", "minimum": 0, "maximum": 5 },
          "reason": { "type": "string", "maxLength": 240 }
        }
      }
    },
    "average_score": { "type": "number", "minimum": 0, "maximum": 5 }
  }
}
